---
import Layout from '../components/layout/Layout.astro';

const colorSwatches = [
  { name: 'Slate', utility: 'bg-slate-950', value: '#020617' },
  { name: 'Stone', utility: 'bg-stone-700', value: '#44403c' },
  { name: 'Emerald', utility: 'bg-emerald-500', value: '#10b981' },
  { name: 'Amber', utility: 'bg-amber-400', value: '#fbbf24' },
  { name: 'Rose', utility: 'bg-rose-500', value: '#f43f5e' },
  { name: 'Sky', utility: 'bg-sky-500', value: '#0ea5e9' }
];

const spacingScale = ['p-2', 'p-3', 'p-4', 'p-6', 'p-8'];
---

<Layout
  title="Dev Lab - Tailwind Showcase"
  description="Pagina di test per utility Tailwind, sezioni base, form, card, tabelle e componenti compositi."
  noindex
>
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-6">
    <section class="grid gap-6 xl:grid-cols-[1.35fr_0.65fr]">
      <div class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_60px_rgba(15,23,42,0.12)] backdrop-blur sm:p-8">
        <div class="flex flex-wrap gap-2">
          <span class="rounded-full bg-slate-900 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.28em] text-white">Tailwind Lab</span>
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.28em] text-emerald-900">Utilities</span>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.28em] text-amber-900">Layout</span>
          <span class="rounded-full bg-sky-100 px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.28em] text-sky-900">Forms</span>
        </div>

        <div class="mt-7 max-w-3xl">
          <p class="text-[11px] font-bold uppercase tracking-[0.42em] text-slate-500">Developer playground</p>
          <h1 class="mt-3 text-4xl font-black uppercase leading-[0.9] tracking-[0.14em] text-slate-950 sm:text-6xl">
            Utility-first
            <span class="block text-slate-500">component atlas</span>
          </h1>
          <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">
            Qui puoi provare la tavolozza classica di Tailwind: spacing, typography, surfaces, buttons, forms, grids, alerts, table e cards, tutto in una sola pagina.
          </p>
        </div>

        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#typography" class="rounded-full bg-slate-950 px-5 py-3 text-xs font-black uppercase tracking-[0.3em] text-white shadow-lg shadow-slate-900/20 transition hover:-translate-y-0.5">Typography</a>
          <a href="#forms" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-xs font-black uppercase tracking-[0.3em] text-slate-800 transition hover:-translate-y-0.5 hover:bg-slate-50">Forms</a>
          <a href="#cards" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-xs font-black uppercase tracking-[0.3em] text-slate-800 transition hover:-translate-y-0.5 hover:bg-slate-50">Cards</a>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-3">
          <div class="rounded-[1.4rem] bg-slate-950 p-5 text-white">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-400">Scale</p>
            <p class="mt-3 text-3xl font-black">01</p>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">Verifica proporzioni, allineamenti e gerarchia dei blocchi.</p>
          </div>
          <div class="rounded-[1.4rem] bg-emerald-50 p-5 text-emerald-950 ring-1 ring-emerald-100">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-emerald-700">Tokens</p>
            <p class="mt-3 text-3xl font-black">02</p>
            <p class="mt-2 text-sm leading-relaxed">Colori e superfici per controllare i contrast ratios.</p>
          </div>
          <div class="rounded-[1.4rem] bg-amber-50 p-5 text-amber-950 ring-1 ring-amber-100">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-amber-700">Density</p>
            <p class="mt-3 text-3xl font-black">03</p>
            <p class="mt-2 text-sm leading-relaxed">Vedi se il layout regge sia stretto che largo.</p>
          </div>
        </div>
      </div>

      <aside class="rounded-[2rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-[0_20px_60px_rgba(15,23,42,0.16)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.38em] text-slate-400">Quick checks</p>
        <div class="mt-4 space-y-3">
          <div class="rounded-[1.25rem] border border-white/10 bg-white/5 p-4">
            <div class="flex items-center justify-between gap-4">
              <span class="text-sm font-semibold">Responsive grid</span>
              <span class="rounded-full bg-emerald-400/15 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-emerald-300">ok</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">Testa card e sezioni su viewport piccoli e grandi.</p>
          </div>
          <div class="rounded-[1.25rem] border border-white/10 bg-white/5 p-4">
            <div class="flex items-center justify-between gap-4">
              <span class="text-sm font-semibold">Form states</span>
              <span class="rounded-full bg-sky-400/15 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-sky-300">ok</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">Controlla focus, disabled, error e spacing interno.</p>
          </div>
          <div class="rounded-[1.25rem] border border-white/10 bg-white/5 p-4">
            <div class="flex items-center justify-between gap-4">
              <span class="text-sm font-semibold">Content rhythm</span>
              <span class="rounded-full bg-amber-400/15 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-amber-300">ok</span>
            </div>
            <p class="mt-2 text-sm leading-relaxed text-slate-300">Verifica titoli, paragrafi, list e tabelle.</p>
          </div>
        </div>
      </aside>
    </section>

    <section id="typography" class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Typography</p>
        <h2 class="mt-3 text-2xl font-black uppercase tracking-[0.18em] text-slate-950">Hierarchy sample</h2>
        <div class="mt-5 space-y-4">
          <h3 class="text-3xl font-black text-slate-950">Display headline</h3>
          <h4 class="text-2xl font-bold text-slate-800">Section heading</h4>
          <p class="text-base leading-7 text-slate-600">
            This paragraph checks readable line-height, link style, and wrapping behavior across widths. <a href="#" class="font-semibold text-sky-700 underline decoration-sky-300 underline-offset-4">Inline link</a> and <code class="rounded bg-slate-100 px-1.5 py-0.5 text-sm text-slate-800">code</code> should sit cleanly inside the flow.
          </p>
          <blockquote class="border-l-4 border-slate-900 bg-slate-50 px-4 py-3 text-slate-700">
            <p class="text-sm leading-7">A blockquote is useful for checking indentation, padding and contrast in content-rich screens.</p>
          </blockquote>
        </div>
      </div>

      <div class="rounded-[1.8rem] border border-slate-200 bg-gradient-to-br from-slate-950 to-slate-800 p-6 text-white shadow-[0_12px_40px_rgba(15,23,42,0.12)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-400">Color system</p>
        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {colorSwatches.map((swatch) => (
            <div class="overflow-hidden rounded-[1.1rem] bg-white/5 ring-1 ring-white/10">
              <div class={`h-20 ${swatch.utility}`}></div>
              <div class="p-3">
                <p class="text-sm font-bold">{swatch.name}</p>
                <p class="text-xs uppercase tracking-[0.2em] text-slate-400">{swatch.value}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Buttons</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <button class="rounded-full bg-slate-950 px-5 py-3 text-xs font-black uppercase tracking-[0.28em] text-white">Primary</button>
          <button class="rounded-full border border-slate-300 bg-white px-5 py-3 text-xs font-black uppercase tracking-[0.28em] text-slate-800">Secondary</button>
          <button class="rounded-full bg-emerald-500 px-5 py-3 text-xs font-black uppercase tracking-[0.28em] text-white">Success</button>
          <button class="rounded-full bg-rose-500 px-5 py-3 text-xs font-black uppercase tracking-[0.28em] text-white">Danger</button>
          <button disabled class="cursor-not-allowed rounded-full bg-slate-200 px-5 py-3 text-xs font-black uppercase tracking-[0.28em] text-slate-400">Disabled</button>
        </div>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          <div class="rounded-[1.2rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">Badges</p>
            <div class="mt-3 flex flex-wrap gap-2">
              <span class="rounded-full bg-slate-950 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-white">New</span>
              <span class="rounded-full bg-amber-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-amber-900">Draft</span>
              <span class="rounded-full bg-emerald-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-emerald-900">Active</span>
            </div>
          </div>
          <div class="rounded-[1.2rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">Progress</p>
            <div class="mt-4 h-3 overflow-hidden rounded-full bg-slate-200">
              <div class="h-full w-3/4 rounded-full bg-sky-500"></div>
            </div>
            <p class="mt-2 text-sm text-slate-600">75% ready</p>
          </div>
        </div>
      </div>

      <div id="forms" class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Forms</p>
        <div class="mt-5 grid gap-4">
          <label class="grid gap-2">
            <span class="text-sm font-semibold text-slate-800">Text input</span>
            <input type="text" value="Tailwind test value" class="rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100" />
          </label>
          <label class="grid gap-2">
            <span class="text-sm font-semibold text-slate-800">Select</span>
            <select class="rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-sky-500 focus:ring-4 focus:ring-sky-100">
              <option>Alpha</option>
              <option>Beta</option>
              <option>Gamma</option>
            </select>
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
              <input type="checkbox" checked class="h-4 w-4 rounded border-slate-400 text-sky-600 focus:ring-sky-500" />
              <span class="text-sm font-medium text-slate-800">Checkbox</span>
            </label>
            <label class="flex items-center gap-3 rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
              <input type="radio" name="demo-radio" checked class="h-4 w-4 border-slate-400 text-sky-600 focus:ring-sky-500" />
              <span class="text-sm font-medium text-slate-800">Radio</span>
            </label>
          </div>
          <label class="grid gap-2">
            <span class="text-sm font-semibold text-slate-800">Range</span>
            <input type="range" min="0" max="100" value="68" class="h-2 w-full cursor-pointer appearance-none rounded-full bg-slate-200 accent-sky-500" />
          </label>
        </div>
      </div>
    </section>

    <section id="cards" class="grid gap-6 xl:grid-cols-[1.25fr_0.75fr]">
      <div class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Cards</p>
            <h2 class="mt-2 text-2xl font-black uppercase tracking-[0.16em] text-slate-950">Reusable layout blocks</h2>
          </div>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-slate-700">3 columns</span>
        </div>

        <div class="mt-5 grid gap-4 md:grid-cols-3">
          <article class="rounded-[1.25rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">Card A</p>
            <h3 class="mt-2 text-lg font-bold text-slate-950">Feature card</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">Useful for nested content and consistent spacing.</p>
          </article>
          <article class="rounded-[1.25rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">Card B</p>
            <h3 class="mt-2 text-lg font-bold text-slate-950">Stats card</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">Great to verify value, label and microcopy rhythm.</p>
          </article>
          <article class="rounded-[1.25rem] border border-slate-200 bg-slate-50 p-4">
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">Card C</p>
            <h3 class="mt-2 text-lg font-bold text-slate-950">Media card</h3>
            <p class="mt-2 text-sm leading-6 text-slate-600">Check image placeholders and action button placement.</p>
          </article>
        </div>
      </div>

      <div class="rounded-[1.8rem] border border-slate-200 bg-slate-950 p-6 text-white shadow-[0_12px_40px_rgba(15,23,42,0.12)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-400">Spacing</p>
        <div class="mt-5 space-y-3">
          {spacingScale.map((space) => (
            <div class="rounded-[1rem] bg-white/5 p-4 ring-1 ring-white/10">
              <div class="flex items-center justify-between gap-3">
                <span class="text-sm font-semibold">{space}</span>
                <span class="text-[10px] uppercase tracking-[0.26em] text-slate-400">sample</span>
              </div>
              <div class={`mt-3 rounded-lg bg-sky-400 ${space}`}></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr]">
      <div class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Alerts</p>
        <div class="mt-5 grid gap-3">
          <div class="rounded-xl border border-sky-200 bg-sky-50 px-4 py-3 text-sky-900">Info message for neutral feedback.</div>
          <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-emerald-900">Success message for positive state.</div>
          <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-amber-900">Warning message for attention.</div>
          <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-rose-900">Error message for invalid input.</div>
        </div>
      </div>

      <div class="rounded-[1.8rem] border border-slate-200 bg-white p-6 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-7">
        <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Table</p>
        <div class="mt-5 overflow-hidden rounded-[1.2rem] border border-slate-200">
          <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-4 py-3 font-black uppercase tracking-[0.2em] text-slate-600">Name</th>
                <th class="px-4 py-3 font-black uppercase tracking-[0.2em] text-slate-600">Status</th>
                <th class="px-4 py-3 font-black uppercase tracking-[0.2em] text-slate-600">Score</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              <tr>
                <td class="px-4 py-3 font-medium text-slate-900">Alpha</td>
                <td class="px-4 py-3 text-slate-600">Ready</td>
                <td class="px-4 py-3 text-slate-600">92</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-slate-900">Beta</td>
                <td class="px-4 py-3 text-slate-600">Draft</td>
                <td class="px-4 py-3 text-slate-600">76</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium text-slate-900">Gamma</td>
                <td class="px-4 py-3 text-slate-600">Blocked</td>
                <td class="px-4 py-3 text-slate-600">41</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </div>
</Layout>
