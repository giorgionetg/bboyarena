---
import Layout from '../components/layout/Layout.astro';

const componentItems = [
  {
    title: 'Profile Card',
    description: 'Avatar, title, metadata and action row in a single reusable block.',
    tone: 'from-slate-950 to-slate-800'
  },
  {
    title: 'Notification Toast',
    description: 'Small fixed-width surface for status messages and close controls.',
    tone: 'from-emerald-600 to-emerald-500'
  },
  {
    title: 'Stat Tile',
    description: 'Dense metric layout for dashboards and comparison widgets.',
    tone: 'from-amber-500 to-amber-400'
  },
  {
    title: 'Command Bar',
    description: 'Search field, shortcut chip and compact button set.',
    tone: 'from-sky-600 to-sky-500'
  }
];
---

<Layout
  title="Dev Lab - Standalone Components"
  description="Pagina per testare componenti singoli, micro layout e blocchi isolati."
  noindex
>
  <div class="mx-auto flex w-full max-w-7xl flex-col gap-6">
    <section class="rounded-[2rem] border border-slate-200 bg-white/90 p-6 shadow-[0_20px_60px_rgba(15,23,42,0.1)] backdrop-blur sm:p-8">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="max-w-3xl">
          <p class="text-[10px] font-black uppercase tracking-[0.38em] text-slate-500">Component sandbox</p>
          <h1 class="mt-3 text-4xl font-black uppercase leading-[0.92] tracking-[0.14em] text-slate-950 sm:text-6xl">
            Standalone
            <span class="block text-slate-500">component snapshots</span>
          </h1>
          <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">
            Ogni blocco qui sotto è isolato per controllare padding, border, radius, overflow, e combinazioni di utility senza il resto della pagina che distrae.
          </p>
        </div>

        <div class="grid gap-2 text-[10px] font-black uppercase tracking-[0.28em] text-slate-500">
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">isolated</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">responsive</span>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2">token check</span>
        </div>
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="grid gap-4">
        {componentItems.map((item) => (
          <article class="overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white shadow-[0_12px_40px_rgba(15,23,42,0.08)]">
            <div class={`h-3 bg-gradient-to-r ${item.tone}`}></div>
            <div class="p-5 sm:p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Component</p>
                  <h2 class="mt-2 text-2xl font-black uppercase tracking-[0.14em] text-slate-950">{item.title}</h2>
                </div>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-slate-700">ready</span>
              </div>
              <p class="mt-3 max-w-xl text-sm leading-7 text-slate-600">{item.description}</p>
              <div class="mt-5 flex flex-wrap gap-3">
                <button class="rounded-full bg-slate-950 px-4 py-2 text-xs font-black uppercase tracking-[0.28em] text-white">Primary</button>
                <button class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-black uppercase tracking-[0.28em] text-slate-800">Secondary</button>
                <button class="rounded-full bg-slate-100 px-4 py-2 text-xs font-black uppercase tracking-[0.28em] text-slate-700">Ghost</button>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="grid gap-6">
        <section class="rounded-[1.75rem] border border-slate-200 bg-slate-950 p-5 text-white shadow-[0_12px_40px_rgba(15,23,42,0.12)] sm:p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-400">Profile card</p>
              <h2 class="mt-2 text-2xl font-black uppercase tracking-[0.14em]">Single component</h2>
            </div>
            <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.26em] text-slate-200">hover</span>
          </div>

          <div class="mt-5 rounded-[1.4rem] border border-white/10 bg-white/5 p-4">
            <div class="flex items-center gap-4">
              <div class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-amber-300 to-rose-400 text-lg font-black text-slate-950">DG</div>
              <div class="min-w-0">
                <p class="text-lg font-bold">Debug Ghost</p>
                <p class="text-sm text-slate-300">UI component hunter</p>
              </div>
              <span class="ml-auto rounded-full bg-emerald-400/15 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-emerald-300">online</span>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-slate-200">avatar</span>
              <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-slate-200">meta</span>
              <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-black uppercase tracking-[0.24em] text-slate-200">actions</span>
            </div>
          </div>
        </section>

        <section class="rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-6">
          <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Command bar</p>
          <div class="mt-4 flex flex-col gap-3 rounded-[1.35rem] border border-slate-200 bg-slate-50 p-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
              <label class="relative flex-1">
                <span class="sr-only">Search</span>
                <input type="text" placeholder="Search components..." class="w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm outline-none transition placeholder:text-slate-400 focus:border-sky-500 focus:ring-4 focus:ring-sky-100" />
              </label>
              <span class="rounded-full border border-slate-300 bg-white px-3 py-2 text-[10px] font-black uppercase tracking-[0.28em] text-slate-700">Ctrl K</span>
            </div>
            <div class="flex flex-wrap gap-2">
              <button class="rounded-full bg-slate-950 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-white">Save</button>
              <button class="rounded-full border border-slate-300 bg-white px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-slate-800">Duplicate</button>
              <button class="rounded-full border border-rose-200 bg-rose-50 px-4 py-2 text-xs font-black uppercase tracking-[0.26em] text-rose-700">Delete</button>
            </div>
          </div>
        </section>

        <section class="rounded-[1.75rem] border border-slate-200 bg-white p-5 shadow-[0_12px_40px_rgba(15,23,42,0.08)] sm:p-6">
          <p class="text-[10px] font-black uppercase tracking-[0.34em] text-slate-500">Mini timeline</p>
          <ol class="mt-5 space-y-4">
            <li class="flex gap-4">
              <span class="mt-1 h-3 w-3 rounded-full bg-emerald-500"></span>
              <div>
                <p class="font-semibold text-slate-950">Mounted</p>
                <p class="text-sm text-slate-600">Verify initial spacing and default styles.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="mt-1 h-3 w-3 rounded-full bg-amber-500"></span>
              <div>
                <p class="font-semibold text-slate-950">Adjusted</p>
                <p class="text-sm text-slate-600">Check layout after a few utility overrides.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="mt-1 h-3 w-3 rounded-full bg-sky-500"></span>
              <div>
                <p class="font-semibold text-slate-950">Ready</p>
                <p class="text-sm text-slate-600">Use as snapshot for future components.</p>
              </div>
            </li>
          </ol>
        </section>
      </div>
    </section>
  </div>
</Layout>
