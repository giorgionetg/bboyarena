---
import Layout from '../components/layout/Layout.astro';
import GameApp from '../game/GameApp';

---

<Layout
  title="Breakdance 3D - Dev Play"
  description="Internal playground for the battle screen and gameplay experiments."
  locale="en-US"
  pagePath="/__dev/play"
  noindex
>
  <div class="dev-play-presenter mx-auto flex w-full max-w-7xl flex-1 flex-col gap-4">
    <section class="dev-play-intro">
      <div>
        <p class="dev-play-kicker">Dev play</p>
        <h1 class="dev-play-title">Battle screen sandbox</h1>
        <p class="dev-play-copy">
          Internal route for gameplay, HUD, crew selection, and battle experiments.
        </p>
      </div>

      <div class="dev-play-tags" aria-label="Presenter notes">
        <span>Stage mode</span>
        <span>Drag camera</span>
        <span>Stamina / combo</span>
        <span>Crew battle</span>
      </div>
    </section>

    <section class="dev-play-stage" aria-label="Game preview stage">
      <GameApp client:only="react" locale="en-US" />
    </section>

    <div class="dev-play-footer-note">
      Internal test space only.
    </div>
  </div>
</Layout>

<style>
  .dev-play-presenter {
    position: relative;
    isolation: isolate;
    padding: 0.25rem 0 0.5rem;
  }

  .dev-play-presenter::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 14%, rgba(159, 181, 95, 0.15), transparent 26%),
      radial-gradient(circle at 50% 82%, rgba(197, 106, 65, 0.14), transparent 24%),
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.045), transparent 56%),
      linear-gradient(180deg, #030303 0%, #050505 42%, #090909 100%);
  }

  .dev-play-presenter::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.08), transparent 18%),
      radial-gradient(ellipse at center, transparent 38%, rgba(0, 0, 0, 0.46) 100%);
    pointer-events: none;
  }

  .dev-play-intro {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 1.5rem;
    background:
      linear-gradient(180deg, rgba(18, 18, 20, 0.94), rgba(10, 10, 12, 0.88)),
      radial-gradient(circle at top, rgba(159, 181, 95, 0.12), transparent 40%);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    padding: 1rem 1.15rem;
    color: #f4efe7;
  }

  .dev-play-kicker {
    margin: 0;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.42em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(214, 229, 154, 0.9);
  }

  .dev-play-title {
    margin: 0.55rem 0 0;
    font-size: clamp(1.35rem, 2.8vw, 2.2rem);
    font-weight: 900;
    letter-spacing: 0.14em;
    line-height: 0.95;
    text-transform: uppercase;
  }

  .dev-play-copy {
    margin: 0.65rem 0 0;
    max-width: 40rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(244, 239, 231, 0.78);
  }

  .dev-play-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .dev-play-tags span {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-bottom-color: rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.45rem 0.8rem;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.26em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(248, 241, 231, 0.86);
    box-shadow: 0 8px 0 rgba(0, 0, 0, 0.28);
  }

  .dev-play-stage {
    position: relative;
    min-height: 68vh;
    overflow: hidden;
    border-radius: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background:
      radial-gradient(circle at 50% 12%, rgba(255, 255, 255, 0.08), transparent 24%),
      linear-gradient(180deg, rgba(5, 5, 5, 0.95), rgba(0, 0, 0, 0.98));
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.66),
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      inset 0 -18px 40px rgba(0, 0, 0, 0.45);
  }

  .dev-play-stage::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse at top center, rgba(255, 255, 255, 0.1), transparent 38%),
      radial-gradient(circle at 50% 50%, transparent 36%, rgba(0, 0, 0, 0.3) 72%, rgba(0, 0, 0, 0.72) 100%);
    opacity: 0.95;
  }

  .dev-play-stage :global(#bboyarena-game-root) {
    min-height: 68vh;
  }

  .dev-play-footer-note {
    align-self: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom-color: rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.5rem 0.95rem;
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.28em;
    line-height: 1;
    text-transform: uppercase;
    color: rgba(244, 239, 231, 0.72);
  }

  @media (max-width: 640px) {
    .dev-play-presenter {
      gap: 0.75rem;
    }

    .dev-play-intro {
      border-radius: 1.2rem;
      padding: 0.9rem;
    }

    .dev-play-stage {
      min-height: 72vh;
      border-radius: 1.4rem;
    }
  }
</style>
