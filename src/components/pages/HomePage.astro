---
import Layout from '../layout/Layout.astro';
import SecondaryCTA from '../cta/SecondaryCTA.astro';
import PanoramaFallback from '../media/PanoramaFallback.astro';
import { buildLocalizedAlternates, buildLocalizedPath, getSiteCopy, type LocaleCode } from '../../lib/i18n';
import { getRecentNewsItems } from '../../lib/news';
import { getHomeCopy } from '../../lib/pages/home';
import { buildPocketBaseDevlogListUrl } from '../../lib/pocketbase';

interface Props {
  locale: LocaleCode;
}

const { locale } = Astro.props as Props;
const copy = getHomeCopy(locale);
const siteCopy = getSiteCopy(locale);
const devlogs = (await getRecentNewsItems(8)).filter((item) => item.category === 'devlog').slice(0, 3);
const manifestoHref = buildLocalizedPath(locale, '/manifesto');
const discordHref = import.meta.env.PUBLIC_DISCORD_URL?.trim() ?? buildLocalizedPath(locale, '/contact');
const instagramHref = import.meta.env.PUBLIC_INSTAGRAM_URL?.trim() ?? buildLocalizedPath(locale, '/contact');
const githubHref =
  import.meta.env.PUBLIC_GITHUB_URL?.trim() ??
  (process.env.GITHUB_REPOSITORY ? `https://github.com/${process.env.GITHUB_REPOSITORY}` : buildLocalizedPath(locale, '/open-development'));
const newsletterHref = import.meta.env.PUBLIC_NEWSLETTER_URL?.trim() ?? buildLocalizedPath(locale, '/contact');
const pocketBaseDevlogListUrl = buildPocketBaseDevlogListUrl(3);
const devlogArchiveHref = buildLocalizedPath(locale, '/news/devlog');
const latestDevlog = devlogs[0];
const latestDevlogHref = latestDevlog
  ? buildLocalizedPath(locale, `/news/${latestDevlog.category}/${latestDevlog.slug}`)
  : devlogArchiveHref;
const devNotesCtaLabel = locale === 'it-IT' ? 'Leggi dev notes' : 'Read dev notes';
---

<Layout
  title={copy.seoTitle}
  description={copy.seoDescription}
  locale={locale}
  pagePath="/"
  canonical={buildLocalizedPath(locale, '/')}
  alternateLinks={buildLocalizedAlternates('/')}
>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
    <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="street-panel flex h-full flex-col rounded-[1.75rem] p-5 sm:p-7">
        <div class="flex flex-wrap items-center gap-2">
          <span class="street-badge-passive rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-[0.28em] text-[#5f5346]">
            {copy.heroLabel}
          </span>
          <span class="text-[10px] font-black uppercase tracking-[0.28em] text-[#756553]" aria-hidden="true">·</span>
          <span class="street-badge-passive rounded-full px-3 py-1 text-[10px] font-black uppercase tracking-[0.28em] text-[#5f5346]">
            {siteCopy.news.eyebrow}
          </span>
        </div>
        <figure class="mt-5 overflow-hidden rounded-[1.35rem] border-2 border-[#4f4337]/65 bg-[#1f1a15] shadow-[0_8px_0_rgba(95,82,69,0.18)]">
          <div
            class="aspect-[1983/793] w-full bg-cover bg-center bg-no-repeat"
            style="background-image: url('/readme-banner.png');"
            role="img"
            aria-label="BboyArena project banner"
          ></div>
        </figure>

        <div class="mt-6 flex flex-1 max-w-2xl flex-col justify-center">
          <p class="text-[11px] font-black uppercase tracking-[0.4em] text-[#6a5b4d]">BboyArena</p>
          <h1 class="mt-3 text-2xl font-black uppercase leading-[0.9] tracking-[0.16em] text-[#2d261f] sm:text-3xl">
            {copy.heroTitle}
          </h1>
          <p class="mt-4 max-w-xl text-sm leading-relaxed text-[#4f4538] sm:text-base">
            {copy.heroLead}
          </p>
        </div>

        <div class="mt-auto flex flex-wrap gap-3 pt-6">
          <a
            href={manifestoHref}
            class="street-button street-button-primary rounded-[1.25rem] px-6 py-3 text-center text-xs font-black uppercase tracking-[0.28em] transition hover:-translate-y-0.5"
          >
            {copy.manifestoCta}
          </a>
          <a
            href={devlogArchiveHref}
            class="street-link-secondary px-1 py-3 text-xs font-black uppercase tracking-[0.24em] transition"
          >
            {copy.archiveCta}<span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <aside class="street-dark flex h-full flex-col overflow-hidden rounded-[1.75rem] p-0">
        <div class="flex min-h-[64svh] flex-1 flex-col gap-4 lg:min-h-0">
          <PanoramaFallback
            image="/equirectangular-01.png"
            fillParent
            overlayTitle={latestDevlog?.title ?? copy.devlogsTitle}
            overlayDescription={latestDevlog?.excerpt ?? copy.devlogsLead}
            overlayCtaHref={latestDevlogHref}
            overlayCtaLabel={devNotesCtaLabel}
          />
        </div>
      </aside>
    </section>
    
    <section class="grid gap-4 lg:grid-cols-2 xl:grid-cols-4">
      <SecondaryCTA
        label={copy.discordLabel}
        title={copy.discordTitle}
        description={copy.discordDescription}
        cta={copy.discordCta}
        href={discordHref}
        icon="discord"
        external={Boolean(import.meta.env.PUBLIC_DISCORD_URL?.trim())}
        buttonPlacement="bottom"
        buttonWidth="full"
      />
      <SecondaryCTA
        label={copy.instagramLabel}
        title={copy.instagramTitle}
        description={copy.instagramDescription}
        cta={copy.instagramCta}
        href={instagramHref}
        icon="instagram"
        external={Boolean(import.meta.env.PUBLIC_INSTAGRAM_URL?.trim())}
        buttonPlacement="bottom"
        buttonWidth="full"
      />
      <SecondaryCTA
        label={copy.githubLabel}
        title={copy.githubTitle}
        description={copy.githubDescription}
        cta={copy.githubCta}
        href={githubHref}
        icon="github"
        external={!import.meta.env.PUBLIC_GITHUB_URL?.trim() && Boolean(process.env.GITHUB_REPOSITORY)}
        buttonPlacement="bottom"
        buttonWidth="full"
      />
      <SecondaryCTA
        label={copy.newsletterLabel}
        title={copy.newsletterTitle}
        description={copy.newsletterDescription}
        cta={copy.newsletterCta}
        href={newsletterHref}
        icon="newsletter"
        external={Boolean(import.meta.env.PUBLIC_NEWSLETTER_URL?.trim())}
        buttonPlacement="bottom"
        buttonWidth="full"
      />
    </section>
  </div>

  {pocketBaseDevlogListUrl && (
    <script define:vars={{ pocketBaseDevlogListUrl, devlogArchiveHref, locale }}>
      {`
        (() => {
          const feed = document.querySelector('[data-pb-devlog-feed]');
          if (!feed) return;

          const escapeHtml = (value) =>
            String(value ?? '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
              .replace(/'/g, '&#39;');

          const renderCard = (item) => {
            const slug = String(item.slug || item.id || '').trim();
            const title = escapeHtml(item.title || 'Untitled devlog');
            const excerpt = escapeHtml(item.excerpt || item.description || '');
            const publishedTime = item.publishedTime || item.created || '';
            const author = escapeHtml(item.author || 'PocketBase');
            const image = item.image ? String(item.image) : '';
            const imageAlt = escapeHtml(item.imageAlt || item.title || 'PocketBase devlog image');

            return \`
              <article class="rounded-[1.25rem] border-2 border-[#4f4337] bg-[rgba(245,237,224,0.08)] p-4">
                <div class="flex flex-wrap items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em]">
                  <span class="street-badge-passive rounded-full border-[#d9e2bf]/30 bg-[rgba(163,185,90,0.12)] px-2.5 py-1 text-[#d9e2bf]">Devlog</span>
                  <span class="text-[#e8ddc6]">${publishedTime ? new Date(publishedTime).toLocaleDateString('${locale}') : ''}</span>
                  ${author ? \`<span class="text-[#bc613a]">${author}</span>\` : ''}
                </div>
                <h3 class="mt-3 text-lg font-black uppercase tracking-[0.12em] text-[#f8f1e7]">${title}</h3>
                <p class="mt-2 text-sm leading-relaxed text-[#f8f1e7]">${excerpt}</p>
                ${image ? \`
                  <div class="mt-4 overflow-hidden rounded-[1rem] border border-[#6a5b4d] bg-[#1f1a15]">
                    <img src="${image}" alt="${imageAlt}" class="h-auto w-full object-cover" loading="lazy" decoding="async" />
                  </div>
                \` : ''}
                <div class="mt-4 flex flex-wrap items-center gap-3 text-[10px] font-black uppercase tracking-[0.24em]">
                  ${slug ? \`
                    <a href="${devlogArchiveHref}/${slug}" class="street-button rounded-full px-3 py-1.5 text-[#2d251d] transition hover:bg-[#f4ebdf]">
                      Read more
                    </a>
                  \` : ''}
                </div>
              </article>
            \`;
          };

          const loadPocketBaseDevlogs = async () => {
            try {
              const response = await fetch(pocketBaseDevlogListUrl, { headers: { Accept: 'application/json' } });
              if (!response.ok) return;

              const payload = await response.json();
              const records = Array.isArray(payload?.items) ? payload.items : [];
              if (records.length === 0) return;

              feed.innerHTML = records.slice(0, 3).map(renderCard).join('');
            } catch {
              // Keep the local fallback silently.
            }
          };

          void loadPocketBaseDevlogs();
        })();
      `}
    </script>
  )}
</Layout>
