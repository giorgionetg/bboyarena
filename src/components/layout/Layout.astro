---
import '../../styles/global.css';
import { buildSeoData } from '../../lib/seo';
import { withBasePath } from '../../lib/base';
import {
  buildLocalizedAlternates,
  buildLocalizedPath,
  getSiteCopy,
  stripLocalePrefix,
  type AlternateLink,
  type LocaleCode
} from '../../lib/i18n';
import HomeLogo from '../navigation/HomeLogo.astro';
import SiteNavigation from '../navigation/SiteNavigation.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  pagePath?: string;
  noindex?: boolean;
  siteName?: string;
  locale?: LocaleCode;
  type?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  alternateLinks?: AlternateLink[];
  localeSwitcherLinks?: { locale: LocaleCode; label: string; path: string }[];
  fullBleedMain?: boolean;
  plainBackground?: boolean;
}

const site = Astro.site ?? (import.meta.env.PUBLIC_SITE_URL ? new URL(import.meta.env.PUBLIC_SITE_URL) : undefined);
const defaultSeoTitle = import.meta.env.PUBLIC_SEO_TITLE ?? 'BboyArena.org';
const defaultSeoDescription =
  import.meta.env.PUBLIC_SEO_DESCRIPTION ??
  'BboyArena.org is an independent, community-driven project about breaking culture, creative movement, and experimental game development, built with open development and privacy-friendly design.';
const defaultSiteName = import.meta.env.PUBLIC_SEO_SITE_NAME ?? 'BboyArena.org';
const defaultLocale = (import.meta.env.PUBLIC_SEO_LOCALE as LocaleCode | undefined) ?? 'en-US';
const defaultImage = import.meta.env.PUBLIC_SEO_OG_IMAGE ?? withBasePath('/og-image.png');
const defaultImageAlt = import.meta.env.PUBLIC_SEO_OG_IMAGE_ALT ?? defaultSeoTitle;
const defaultLogo = import.meta.env.PUBLIC_SEO_LOGO ?? withBasePath('/favicon.svg');
const defaultTwitterSite = import.meta.env.PUBLIC_SEO_TWITTER_SITE;
const defaultTwitterCreator = import.meta.env.PUBLIC_SEO_TWITTER_CREATOR;
const defaultAuthor = import.meta.env.PUBLIC_SEO_AUTHOR ?? defaultSiteName;

const { 
  title = defaultSeoTitle, 
  description = defaultSeoDescription,
  canonical,
  pagePath,
  noindex = false,
  siteName = defaultSiteName,
  locale = defaultLocale,
  type = 'website',
  image = defaultImage,
  imageAlt = defaultImageAlt,
  twitterCard = 'summary_large_image',
  author = defaultAuthor,
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  alternateLinks,
  localeSwitcherLinks,
  fullBleedMain = false,
  plainBackground = false
} = Astro.props;

const copy = getSiteCopy(locale);
const logicalPath = pagePath ?? stripLocalePrefix(Astro.url.pathname);
const resolvedCanonical = canonical ?? buildLocalizedPath(locale, logicalPath);
const resolvedAlternates = alternateLinks ?? buildLocalizedAlternates(logicalPath);
const discordHref = import.meta.env.PUBLIC_DISCORD_URL?.trim();
const githubHref = import.meta.env.PUBLIC_GITHUB_URL ?? (process.env.GITHUB_REPOSITORY ? `https://github.com/${process.env.GITHUB_REPOSITORY}` : undefined);
const footerLinks = [
  { label: copy.footer.manifesto, href: buildLocalizedPath(locale, '/manifesto') },
  { label: copy.footer.privacy, href: buildLocalizedPath(locale, '/privacy') },
  { label: copy.footer.cookies, href: buildLocalizedPath(locale, '/cookies') },
  { label: copy.footer.terms, href: buildLocalizedPath(locale, '/terms') },
  { label: copy.footer.openSource, href: buildLocalizedPath(locale, '/open-development') },
  { label: copy.footer.participate, href: buildLocalizedPath(locale, '/news') },
  { label: copy.footer.contact, href: buildLocalizedPath(locale, '/contact') },
];
const footerSecondaryLinks = [
  ...footerLinks.slice(4),
  ...(discordHref ? [{ label: copy.footer.discord, href: discordHref, external: true }] : []),
  ...(githubHref ? [{ label: copy.footer.github, href: githubHref, external: true }] : [])
];

const seo = buildSeoData({
  siteUrl: site,
  currentUrl: Astro.url,
  title,
  description,
  canonical: resolvedCanonical,
  noindex,
  siteName,
  locale,
  type,
  image,
  imageAlt,
  logo: defaultLogo,
  twitterCard,
  twitterSite: defaultTwitterSite,
  twitterCreator: defaultTwitterCreator,
  author,
  publishedTime,
  modifiedTime,
  section,
  tags
});
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <link rel="canonical" href={seo.canonicalUrl} />
    {resolvedAlternates.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="robots" content={seo.robotsContent} />
    <meta name="theme-color" content="#8f8371" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonicalUrl} />
    {seo.imageUrl && <meta property="og:image" content={seo.imageUrl} />}
    {seo.imageUrl && <meta property="og:image:alt" content={imageAlt} />}
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && section && <meta property="article:section" content={section} />}
    {type === 'article' && author && <meta property="article:author" content={author} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content={twitterCard} />
    {defaultTwitterSite && <meta name="twitter:site" content={defaultTwitterSite} />}
    {defaultTwitterCreator && <meta name="twitter:creator" content={defaultTwitterCreator} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {seo.imageUrl && <meta name="twitter:image" content={seo.imageUrl} />}
    {seo.imageUrl && <meta name="twitter:image:alt" content={imageAlt} />}
    {plainBackground && (
      <style is:global>
        {`
          html,
          body.manifesto-plain-bg {
            background: #eae0d0 !important;
            background-image: none !important;
          }

          body.manifesto-plain-bg::before,
          body.manifesto-plain-bg::after {
            content: none !important;
            display: none !important;
          }
        `}
      </style>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
  </head>
  <body
    class={`min-h-screen flex flex-col justify-between text-[#241f18] selection:bg-[#9fb55f] selection:text-white ${plainBackground ? 'manifesto-plain-bg' : ''}`}
    style={plainBackground ? 'background:#eae0d0 !important; background-image:none !important;' : undefined}
  >
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 w-full border-b-4 border-[#4f4337] bg-[rgba(234,224,208,0.95)] shadow-[0_4px_0_rgba(95,82,69,0.7)]">
      <div class="mx-auto max-w-6xl px-4 py-3 sm:py-4">
        <SiteNavigation locale={locale} pagePath={logicalPath} localeSwitcherLinks={localeSwitcherLinks} />
      </div>
    </header>

    <!-- Main Container -->
    <main
      class={`flex w-full flex-grow flex-col justify-center ${
        fullBleedMain ? 'bg-[rgba(234,224,208,0.95)] px-4 py-8 sm:py-10' : 'mx-auto max-w-6xl px-4 py-6 sm:py-8'
      }`}
    >
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full border-t-4 border-[#4f4337] bg-[rgba(234,224,208,0.92)] py-6 shadow-[0_-4px_0_rgba(95,82,69,0.55)] sm:py-7">
      <div class="mx-auto max-w-6xl px-4 text-[11px] text-[#5f5346] sm:text-[12px]">
        <div class="grid gap-6 lg:grid-cols-[auto_1fr] lg:items-start">
          <div class="flex flex-col items-center gap-3 text-center lg:items-start lg:text-left">
            <div class="flex justify-center lg:justify-start">
              <HomeLogo locale={locale} label="BboyArena home" />
            </div>
            <div class="uppercase tracking-[0.22em]">&copy; {new Date().getFullYear()} BboyArena.org.</div>
          </div>

          <div class="grid w-full justify-items-center gap-4 sm:grid-cols-2 lg:ml-auto lg:w-fit lg:grid-cols-[max-content_max-content] lg:justify-items-end lg:gap-x-12 lg:gap-y-2 lg:px-7 xl:px-8">
            <div class="flex w-full flex-col items-center gap-1 lg:w-auto lg:items-end lg:pr-1">
              {footerLinks.slice(0, 4).map((link) => (
                <a
                  href={link.href}
                  class="block w-full py-1 text-center uppercase tracking-[0.2em] text-[#2d251d] transition hover:text-[#7b6b58] lg:text-right"
                >
                  <span>{link.label}</span>
                </a>
              ))}
            </div>

            <div class="flex w-full flex-col items-center gap-1 lg:w-auto lg:items-end lg:pl-1">
              {footerSecondaryLinks.map((link) => (
                <a
                  href={link.href}
                  class="block w-full py-1 text-center uppercase tracking-[0.2em] text-[#2d251d] transition hover:text-[#7b6b58] lg:text-right"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noreferrer noopener' : undefined}
                >
                  <span>{link.label}</span>
                  {link.external && <span class="ml-2 text-[9px] tracking-[0.18em] text-[#5f5346] lg:ml-2">External</span>}
                </a>
              ))}

            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
