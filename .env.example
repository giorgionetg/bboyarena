PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PUBLIC_SITE_URL=https://bboyarena.org
# Local fallback only; GitHub Actions overrides this with the commit SHA.
PUBLIC_APP_VERSION=dev
PUBLIC_DISCORD_URL=https://discord.gg/AkXygNjC
PUBLIC_CONTACT_EMAIL=info@bboyarena.org
PUBLIC_NEWSLETTER_URL=https://your-newsletter.example.com
PUBLIC_GITHUB_URL=

# Optional PocketBase live content source for devlogs
PUBLIC_POCKETBASE_URL=
PUBLIC_POCKETBASE_DEVLOGS_COLLECTION=devlogs
# Example: status = "published"
PUBLIC_POCKETBASE_DEVLOGS_FILTER=

# SEO / metadata defaults
PUBLIC_SEO_SITE_NAME=BboyArena.org
PUBLIC_SEO_TITLE=BboyArena.org
PUBLIC_SEO_DESCRIPTION=BboyArena.org is an independent, community-driven project about breaking culture, creative movement, and experimental game development, built with open development and privacy-friendly design.
PUBLIC_SEO_OG_IMAGE=/og-image.png
PUBLIC_SEO_OG_IMAGE_ALT=BboyArena.org cover image
PUBLIC_SEO_LOGO=/icon.png
PUBLIC_SEO_LOCALE=it_IT
PUBLIC_SEO_TWITTER_SITE=@breakdance3d
PUBLIC_SEO_TWITTER_CREATOR=@breakdance3d
PUBLIC_SEO_AUTHOR=BboyArena.org Editorial

# Optional external news source for the "scene" category
PUBLIC_NEWS_EXTERNAL_FEED_URL=
PUBLIC_NEWS_EXTERNAL_SOURCE_NAME=
PUBLIC_NEWS_EXTERNAL_SOURCE_URL=

# Optional override used by Astro config when you need a custom base path
# Example for GitHub Pages project sites: /your-repo/
ASTRO_BASE_PATH=/

# Docker / infrastructure
POSTGRES_PASSWORD=postgres
JWT_SECRET=change-me-change-me-change-me-change-me
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
TRAEFIK_DASHBOARD_HOST=traefik.localhost
FRONTEND_HOST=game.localhost
SUPABASE_HOST=supabase.localhost
SUPABASE_STUDIO_HOST=studio.localhost
COLYSEUS_HOST=ws.localhost
COLYSEUS_PUBLIC_URL=ws://ws.localhost
