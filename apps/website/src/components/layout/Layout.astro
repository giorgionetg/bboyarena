---
import '../../styles/global.css';
import { buildSeoData } from '../../lib/seo';
import { withBasePath } from '../../lib/base';
import { pwaInfo } from 'virtual:pwa-info';
import navData from '../../data/navigation.json';
import {
  buildLocalizedAlternates,
  buildLocalizedPath,
  getSiteCopy,
  stripLocalePrefix,
  type AlternateLink,
  type LocaleCode
} from '../../lib/i18n';
import HomeLogo from '../navigation/HomeLogo.astro';
import SiteNavigation from '../navigation/SiteNavigation.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  pagePath?: string;
  noindex?: boolean;
  siteName?: string;
  locale?: LocaleCode;
  type?: 'website' | 'article';
  image?: string;
  imageAlt?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  author?: string;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
  alternateLinks?: AlternateLink[];
  localeSwitcherLinks?: { locale: LocaleCode; label: string; path: string }[];
  fullBleedMain?: boolean;
  plainBackground?: boolean;
}

const site = Astro.site ?? (import.meta.env.PUBLIC_SITE_URL ? new URL(import.meta.env.PUBLIC_SITE_URL) : undefined);
const defaultSeoTitle = import.meta.env.PUBLIC_SEO_TITLE ?? 'BboyArena.org';
const defaultSeoDescription =
  import.meta.env.PUBLIC_SEO_DESCRIPTION ??
  'BboyArena.org is an independent, community-driven project about breaking culture, creative movement, and experimental game development, built with open development and privacy-friendly design.';
const appVersion = import.meta.env.PUBLIC_APP_VERSION?.trim() ?? process.env.GITHUB_SHA ?? 'dev';
const defaultSiteName = import.meta.env.PUBLIC_SEO_SITE_NAME ?? 'BboyArena.org';
const defaultLocale = (import.meta.env.PUBLIC_SEO_LOCALE as LocaleCode | undefined) ?? 'en-US';
const defaultImage = import.meta.env.PUBLIC_SEO_OG_IMAGE ?? withBasePath('/og-image.png');
const defaultImageAlt = import.meta.env.PUBLIC_SEO_OG_IMAGE_ALT ?? defaultSeoTitle;
const defaultLogo = import.meta.env.PUBLIC_SEO_LOGO ?? withBasePath('/favicon.svg');
const defaultTwitterSite = import.meta.env.PUBLIC_SEO_TWITTER_SITE;
const defaultTwitterCreator = import.meta.env.PUBLIC_SEO_TWITTER_CREATOR;
const defaultAuthor = import.meta.env.PUBLIC_SEO_AUTHOR ?? defaultSiteName;
const chromeColor = '#eae0d0';
const enableVersioning = import.meta.env.PROD;
const repoName = process.env.GITHUB_REPOSITORY?.split('/')[1] ?? '';
const officialOrigin = site?.origin ?? '';
const legacyProjectBase = repoName ? `/${repoName}` : '';

const { 
  title = defaultSeoTitle, 
  description = defaultSeoDescription,
  canonical,
  pagePath,
  noindex = false,
  siteName = defaultSiteName,
  locale = defaultLocale,
  type = 'website',
  image = defaultImage,
  imageAlt = defaultImageAlt,
  twitterCard = 'summary_large_image',
  author = defaultAuthor,
  publishedTime,
  modifiedTime,
  section,
  tags = [],
  alternateLinks,
  localeSwitcherLinks,
  fullBleedMain = false,
  plainBackground = false
} = Astro.props;

const copy = getSiteCopy(locale);
const logicalPath = pagePath ?? stripLocalePrefix(Astro.url.pathname);
const resolvedCanonical = canonical ?? buildLocalizedPath(locale, logicalPath);
const resolvedAlternates = alternateLinks ?? buildLocalizedAlternates(logicalPath);
const isDevRoute = logicalPath.startsWith('/__dev');
const devlogsPath = buildLocalizedPath(locale, '/news/devlog');
const discordHref = import.meta.env.PUBLIC_DISCORD_URL?.trim();
const instagramHref = import.meta.env.PUBLIC_INSTAGRAM_URL?.trim();
const githubRepository = process.env.GITHUB_REPOSITORY ?? 'giorgionetg/bboyarena';
const githubHref = import.meta.env.PUBLIC_GITHUB_URL?.trim() ?? `https://github.com/${githubRepository}`;
const githubLabel = githubRepository.split('/').pop() ?? 'GitHub';
const sameAs = [instagramHref, discordHref, githubHref].filter((value): value is string => Boolean(value));
const analyticsScriptUrl = import.meta.env.PUBLIC_ANALYTICS_SCRIPT_URL?.trim();
const analyticsWebsiteId = import.meta.env.PUBLIC_ANALYTICS_WEBSITE_ID?.trim();
const footerLinks = [
  { label: copy.footer.manifesto, href: buildLocalizedPath(locale, '/manifesto') },
  { label: copy.footer.privacy, href: buildLocalizedPath(locale, '/privacy') },
  { label: copy.footer.cookies, href: buildLocalizedPath(locale, '/cookies') },
  { label: copy.footer.terms, href: buildLocalizedPath(locale, '/terms') },
];
const footerSecondaryLinks = footerLinks.slice(4);
const headerNavLinks = isDevRoute
  ? [
      { label: copy.nav.manifesto, path: '/manifesto' },
      { label: 'Devlogs', path: '/news/devlog' }
    ]
  : (navData.items as { key: keyof typeof copy.nav; path: string }[]).map((item) => ({
      label: copy.nav[item.key],
      path: item.path
    }));
const footerSocialLinks = [
  ...(instagramHref
    ? [{ label: 'Instagram', href: instagramHref, external: true, icon: 'instagram' as const }]
    : []),
  ...(discordHref ? [{ label: copy.footer.discord, href: discordHref, external: true, icon: 'discord' as const }] : []),
  ...(githubHref ? [{ label: copy.footer.github, href: githubHref, external: true, icon: 'github' as const }] : [])
];

const seo = buildSeoData({
  siteUrl: site,
  currentUrl: Astro.url,
  title,
  description,
  canonical: resolvedCanonical,
  noindex,
  siteName,
  locale,
  type,
  image,
  imageAlt,
  logo: defaultLogo,
  twitterCard,
  twitterSite: defaultTwitterSite,
  twitterCreator: defaultTwitterCreator,
  author,
  sameAs,
  publishedTime,
  modifiedTime,
  section,
  tags
});

const manifestLinkTag =
  pwaInfo?.webManifest.linkTag ?? `<link rel="manifest" href="${withBasePath('/manifest.webmanifest')}" />`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {officialOrigin && (
      <script is:inline define:vars={{ officialOrigin, legacyProjectBase }}>
        {`
          (() => {
            const hostname = window.location.hostname;
            const isGithubPagesHost = hostname === 'github.io' || hostname.endsWith('.github.io');
            if (!isGithubPagesHost) return;

            const pathname = window.location.pathname;
            let nextPath = pathname;

            if (legacyProjectBase && (pathname === legacyProjectBase || pathname.startsWith(`${legacyProjectBase}/`))) {
              nextPath = pathname.slice(legacyProjectBase.length) || '/';
            }

            if (!nextPath.startsWith('/')) {
              nextPath = `/${nextPath}`;
            }

            const target = new URL(nextPath + window.location.search + window.location.hash, officialOrigin);

            const overlay = document.createElement('div');
            overlay.id = 'official-site-redirect';
            overlay.setAttribute('role', 'status');
            overlay.setAttribute('aria-live', 'polite');
            overlay.style.cssText = [
              'position:fixed',
              'inset:0',
              'z-index:9999',
              'display:flex',
              'align-items:center',
              'justify-content:center',
              'padding:1rem',
              'background:rgba(234,224,208,0.98)',
              'color:#241f18',
              'font-family:Arial, Helvetica, sans-serif',
              'text-align:center'
            ].join(';');

            overlay.innerHTML = `
              <div style="max-width:22rem;border:2px solid #4f4337;border-radius:1.25rem;background:#f4ebdf;padding:1rem 1.1rem;box-shadow:0 12px 0 rgba(95,82,69,0.22)">
                <div style="font-size:0.7rem;font-weight:900;letter-spacing:0.28em;text-transform:uppercase;color:#756553;margin-bottom:0.65rem">Redirecting</div>
                <div style="font-size:1rem;font-weight:700;line-height:1.5">Taking you to the official site...</div>
                <div style="margin-top:0.5rem;font-size:0.8rem;line-height:1.5;color:#5f5346">If the redirect takes a moment, the browser is moving you to the canonical BboyArena domain.</div>
              </div>
            `;

            const run = async () => {
              try {
                document.documentElement.appendChild(overlay);
              } catch {
                // Ignore DOM insertion failures and continue with the redirect.
              }

              try {
                if ('serviceWorker' in navigator) {
                  const registrations = await navigator.serviceWorker.getRegistrations();
                  await Promise.all(registrations.map((registration) => registration.unregister()));
                }
              } catch {
                // Ignore cleanup failures and continue with the redirect.
              }

              try {
                if ('caches' in window) {
                  const cacheKeys = await caches.keys();
                  await Promise.all(cacheKeys.map((key) => caches.delete(key)));
                }
              } catch {
                // Ignore cache cleanup failures and continue with the redirect.
              }

              window.location.replace(target.toString());
            };

            void run();
          })();
        `}
      </script>
    )}
    <link rel="icon" type="image/png" href={withBasePath('/icon.png')} />
    <link rel="icon" type="image/svg+xml" href={withBasePath('/favicon.svg')} />
    <link rel="icon" type="image/png" sizes="192x192" href={withBasePath('/android-chrome-192x192.png')} />
    <link rel="icon" type="image/png" sizes="512x512" href={withBasePath('/android-chrome-512x512.png')} />
    <link rel="apple-touch-icon" sizes="180x180" href={withBasePath('/apple-touch-icon.png')} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content={siteName} />
    <meta name="bboyarena-app-version" content={appVersion} />
    <meta name="msapplication-navbutton-color" content={chromeColor} />
    <Fragment set:html={manifestLinkTag} />
    <link rel="canonical" href={seo.canonicalUrl} />
    {resolvedAlternates.map((link) => (
      <link rel="alternate" hreflang={link.hreflang} href={link.href} />
    ))}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <meta name="robots" content={seo.robotsContent} />
    <meta name="theme-color" content={chromeColor} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonicalUrl} />
    {seo.imageUrl && <meta property="og:image" content={seo.imageUrl} />}
    {seo.imageUrl && <meta property="og:image:alt" content={imageAlt} />}
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && section && <meta property="article:section" content={section} />}
    {type === 'article' && author && <meta property="article:author" content={author} />}
    {type === 'article' && tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content={twitterCard} />
    {defaultTwitterSite && <meta name="twitter:site" content={defaultTwitterSite} />}
    {defaultTwitterCreator && <meta name="twitter:creator" content={defaultTwitterCreator} />}
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {seo.imageUrl && <meta name="twitter:image" content={seo.imageUrl} />}
    {seo.imageUrl && <meta name="twitter:image:alt" content={imageAlt} />}
    {plainBackground && (
      <style is:global>
        {`
          html,
          body.manifesto-plain-bg {
            background: #eae0d0 !important;
            background-image: none !important;
          }

          body.manifesto-plain-bg::before,
          body.manifesto-plain-bg::after {
            content: none !important;
            display: none !important;
          }
        `}
      </style>
    )}
    <script type="application/ld+json" set:html={JSON.stringify(seo.jsonLd)} />
    {analyticsScriptUrl && analyticsWebsiteId && (
      <script
        defer
        src={analyticsScriptUrl}
        data-website-id={analyticsWebsiteId}
      ></script>
    )}
    {enableVersioning && (
      <script is:inline>
        {`
          (() => {
            if (!('serviceWorker' in navigator)) return;

            const swUrl = ${JSON.stringify(withBasePath('/sw.js'))};
            const swScope = ${JSON.stringify(withBasePath('/'))};

            const register = async () => {
              try {
                const registration = await navigator.serviceWorker.register(swUrl, {
                  scope: swScope,
                  type: 'classic',
                  updateViaCache: 'none'
                });

                try {
                  await registration.update();
                } catch {
                  // Ignore update failures and keep the existing registration.
                }
              } catch {
                // Ignore registration failures silently; the app still works without SW.
              }
            };

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', register, { once: true });
            } else {
              void register();
            }
          })();
        `}
      </script>
      <script define:vars={{ appVersion }}>
      {`
        (() => {
          const storageKey = 'bboyarena-app-version';
          const bannerId = 'bboyarena-update-banner';

          const safeGet = () => {
            try {
              return window.localStorage.getItem(storageKey);
            } catch {
              return null;
            }
          };

          const safeSet = (value) => {
            try {
              window.localStorage.setItem(storageKey, value);
            } catch {
              // Ignore storage failures in private mode or restricted contexts.
            }
          };

          const removeBanner = () => {
            document.getElementById(bannerId)?.remove();
          };

          const showBanner = () => {
            if (document.getElementById(bannerId)) return;

            const banner = document.createElement('div');
            banner.id = bannerId;
            banner.setAttribute('role', 'status');
            banner.setAttribute('aria-live', 'polite');
            banner.className =
              'fixed bottom-4 left-4 right-4 z-[999] mx-auto flex max-w-xl flex-col gap-3 rounded-[1.25rem] border-2 border-[#4f4337] bg-[#f4ebdf] p-4 shadow-[0_12px_0_rgba(95,82,69,0.25)] sm:flex-row sm:items-center sm:justify-between';

            banner.innerHTML = `
              <div class="text-sm leading-relaxed text-[#2d261f]">
                <strong class="block text-[10px] font-black uppercase tracking-[0.24em] text-[#756553]">Aggiornamento disponibile</strong>
                <span>È stata pubblicata una nuova versione dell'app. Ricarica per aggiornare i contenuti.</span>
              </div>
              <div class="flex gap-2">
                <button type="button" data-update-dismiss class="street-button inline-flex h-11 items-center justify-center rounded-full px-4 text-[10px] font-black uppercase tracking-[0.24em]">Più tardi</button>
                <button type="button" data-update-reload class="street-button street-button-primary inline-flex h-11 items-center justify-center rounded-full px-4 text-[10px] font-black uppercase tracking-[0.24em]">Ricarica ora</button>
              </div>
            `;

            banner.querySelector('[data-update-dismiss]')?.addEventListener('click', removeBanner);
            banner.querySelector('[data-update-reload]')?.addEventListener('click', async () => {
              try {
                const registration = await navigator.serviceWorker.getRegistration();
                await registration?.update();
              } catch {
                // Ignore update errors and fall through to reload.
              }

              window.location.reload();
            });

            document.body.appendChild(banner);
          };

          const syncVersion = () => {
            const storedVersion = safeGet();

            if (!storedVersion) {
              safeSet(appVersion);
              return;
            }

            if (storedVersion !== appVersion) {
              showBanner();
            }
          };

          if ('serviceWorker' in navigator) {
            navigator.serviceWorker.addEventListener('controllerchange', () => {
              safeSet(appVersion);
              window.location.reload();
            });
          }

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', syncVersion, { once: true });
          } else {
            syncVersion();
          }
        })();
      `}
      </script>
    )}
  </head>
  <body
    class={`min-h-screen flex flex-col justify-between text-[#241f18] selection:bg-[#9fb55f] selection:text-white ${plainBackground ? 'manifesto-plain-bg' : ''}`}
    style={plainBackground ? 'background:#eae0d0 !important; background-image:none !important;' : undefined}
  >
    <div class="os-ribbon-shell">
      <a
        href={githubHref}
        target="_blank"
        rel="noreferrer noopener"
        aria-label={`Open source repository on ${githubLabel}`}
        class="os-ribbon group"
      >
        <span class="os-ribbon__inner">
          <span class="os-ribbon__content">
            <svg viewBox="0 0 24 24" class="os-ribbon__icon" aria-hidden="true">
              <path
                d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.2 7 9.5.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.7.1-.7.1-.7 1 0 1.6 1 1.6 1 .9 1.6 2.3 1.2 2.9.9.1-.7.4-1.2.7-1.5-2.3-.3-4.7-1.1-4.7-5 0-1.1.4-2.1 1.1-2.8-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1.1a9.7 9.7 0 0 1 5 0c1.9-1.4 2.8-1.1 2.8-1.1.6 1.4.2 2.4.1 2.7.7.7 1.1 1.7 1.1 2.8 0 3.9-2.4 4.7-4.7 5 .4.4.8 1.2.8 2.4v3.6c0 .3.2.6.7.5 4.1-1.3 7-5.1 7-9.5 0-5.5-4.5-10-10-10Z"
                fill="currentColor"
              />
            </svg>
            <span>GitHub</span>
          </span>
        </span>
      </a>
    </div>

    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 w-full border-b-4 border-[#4f4337] bg-[#eae0d0] shadow-[0_4px_0_rgba(95,82,69,0.7)]">
      <div class="mx-auto max-w-6xl px-4 py-3 sm:py-4">
        <SiteNavigation locale={locale} pagePath={logicalPath} localeSwitcherLinks={localeSwitcherLinks} navLinks={headerNavLinks} />
      </div>
    </header>

    <!-- Main Container -->
    <main
      class={`flex w-full flex-grow flex-col justify-center ${
        fullBleedMain ? 'bg-[#eae0d0] px-4 py-8 sm:py-10' : 'mx-auto max-w-6xl px-4 py-6 sm:py-8'
      }`}
    >
      <slot />
    </main>

    <!-- Footer -->
    <footer class="w-full border-t-4 border-[#4f4337] bg-[#eae0d0] py-6 shadow-[0_-4px_0_rgba(95,82,69,0.55)] sm:py-7">
      <div class="mx-auto max-w-6xl px-4 text-[11px] text-[#5f5346] sm:text-[12px]">
        <div class="grid gap-6 lg:grid-cols-[auto_1fr] lg:items-start">
          <div class="flex flex-col items-center gap-3 text-center lg:items-start lg:text-left">
            <div class="flex justify-center lg:justify-start">
              <HomeLogo locale={locale} label="BboyArena home" />
            </div>
            {footerSocialLinks.length > 0 && (
              <div class="flex items-center justify-center gap-3 lg:justify-start" aria-label="Social links">
                {footerSocialLinks.map((link) => (
                  <a
                    href={link.href}
                    class="flex h-9 w-9 items-center justify-center rounded-full border border-[#4f4337]/60 bg-[#f4ebdf] text-[#2d251d] transition hover:-translate-y-0.5 hover:bg-[#e8ddc6] hover:text-[#7b6b58]"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noreferrer noopener' : undefined}
                    aria-label={link.label}
                    title={link.label}
                  >
                    {link.icon === 'instagram' && (
                      <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" aria-hidden="true">
                        <path
                          d="M7.5 4A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm0 1.5h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2Zm9.75 1.1a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8ZM12 7.1A4.9 4.9 0 1 0 16.9 12 4.91 4.91 0 0 0 12 7.1Zm0 1.5A3.4 3.4 0 1 1 8.6 12 3.4 3.4 0 0 1 12 8.6Z"
                          fill="currentColor"
                        />
                      </svg>
                    )}
                    {link.icon === 'discord' && (
                      <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" aria-hidden="true">
                        <path
                          d="M7.4 7.2c1.1-.5 2.2-.8 3.5-.9l.1.2c-1.2.2-2.2.6-3 .9-.1 0-.2-.1-.3-.2Zm9.2 0c-.1.1-.2.2-.3.2-.8-.4-1.8-.7-3-.9l.1-.2c1.3.1 2.4.4 3.5.9ZM5.5 7.7c-1.1 1.4-1.8 3.3-1.8 5.4 0 1.6.4 3.1 1.1 4.4 1.5 1 3.2 1.7 5 2 .2-.4.4-.8.5-1.2-1-.1-1.8-.4-2.4-.8.5.1 1.1.2 1.7.3 1.1.1 2.2.1 3.2 0 1.1-.1 1.9-.2 2.4-.3-.6.4-1.4.7-2.4.8.1.4.3.8.5 1.2 1.8-.3 3.5-1 5-2 .7-1.3 1.1-2.8 1.1-4.4 0-2.1-.7-4-1.8-5.4-1.4-.6-2.8-1-4.2-1.2l-.5 1c-1-.1-1.9-.1-2.9 0l-.5-1c-1.4.2-2.8.6-4.2 1.2Zm4 5.8c0 .7-.5 1.3-1.2 1.3-.7 0-1.2-.6-1.2-1.3s.5-1.3 1.2-1.3c.7 0 1.2.6 1.2 1.3Zm6.4 0c0 .7-.5 1.3-1.2 1.3-.7 0-1.2-.6-1.2-1.3s.5-1.3 1.2-1.3c.7 0 1.2.6 1.2 1.3Z"
                          fill="currentColor"
                        />
                      </svg>
                    )}
                    {link.icon === 'github' && (
                      <svg viewBox="0 0 24 24" class="h-4.5 w-4.5" aria-hidden="true">
                        <path
                          d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.1 6.8 9.4.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.5 1 1.5 1 1 .1 1.5.7 1.7 1 .4.8 1 1.1 1.4 1.2.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.1-4.7-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.4.1-2.8 0 0 .8-.3 2.7 1a9.2 9.2 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.5.1 2.8.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.7 5 .4.3.8.9.8 1.8v2.7c0 .3.2.6.7.5A10 10 0 0 0 22 12C22 6.5 17.5 2 12 2Z"
                          fill="currentColor"
                        />
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            )}
            <div class="uppercase tracking-[0.22em]">&copy; {new Date().getFullYear()} BboyArena.org.</div>
          </div>

          <div class="grid w-full justify-items-center gap-4 sm:grid-cols-2 lg:ml-auto lg:w-fit lg:grid-cols-[max-content_max-content] lg:justify-items-end lg:gap-x-12 lg:gap-y-2 lg:px-7 xl:px-8">
            <div class="flex w-full flex-col items-center gap-1 lg:w-auto lg:items-end lg:pr-1">
              {footerLinks.slice(0, 4).map((link) => (
                <a
                  href={link.href}
                  class="block w-full py-1 text-center uppercase tracking-[0.2em] text-[#2d251d] transition hover:text-[#7b6b58] lg:text-right"
                >
                  <span>{link.label}</span>
                </a>
              ))}
            </div>

            {footerSecondaryLinks.length > 0 && (
              <div class="flex w-full flex-col items-center gap-1 lg:w-auto lg:items-end lg:pl-1">
                {footerSecondaryLinks.map((link) => (
                  <a
                    href={link.href}
                    class="block w-full py-1 text-center uppercase tracking-[0.2em] text-[#2d251d] transition hover:text-[#7b6b58] lg:text-right"
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noreferrer noopener' : undefined}
                  >
                    <span>{link.label}</span>
                    {link.external && <span class="ml-2 text-[9px] tracking-[0.18em] text-[#5f5346] lg:ml-2">External</span>}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
