---
import Layout from '../layout/Layout.astro';
import { buildLocalizedAlternates, getLocaleSwitcherLinks, type LocaleCode } from '../../lib/i18n';

interface Props {
  locale?: LocaleCode;
}

const { locale = 'en-US' } = Astro.props;
const defaultGameEmbedUrl = import.meta.env.DEV ? 'http://localhost:4322/' : 'https://bboyarena.org.com/game/';
const gameEmbedUrl = import.meta.env.PUBLIC_GAME_EMBED_URL?.trim() || defaultGameEmbedUrl;
const hasGameEmbed = Boolean(gameEmbedUrl);

const copy = {
  eyebrow: 'Browser game showroom',
  title: 'Play the standalone game inside the website.',
  lead:
    'This page embeds the standalone BboyArena game runtime in a website shell, so we can test the future player-facing experience without mixing the game code back into Astro.',
  seoTitle: 'Play the BboyArena game prototype',
  seoDescription:
    'Open the BboyArena standalone game prototype in an embedded showroom page with setup notes, controls, and development instructions.',
  launchLabel: 'Embedded runtime',
  launchTitle: 'Game iframe',
  launchText:
    'In development, keep the game server running on port 4322 and the website server on port 4321. The iframe below will load the standalone game app.',
  missingTitle: 'Game server not configured',
  missingText:
    'Set PUBLIC_GAME_EMBED_URL to the standalone game URL, or run the website in development where the default is http://localhost:4322/.',
  setupTitle: 'How to run it locally',
  setupLead: 'Use two terminals so the website and game stay independent.',
  steps: [
    {
      label: 'Terminal 1',
      command: 'npm run game:dev',
      description: 'Starts the standalone game app on http://localhost:4322/.'
    },
    {
      label: 'Terminal 2',
      command: 'npm run dev',
      description: 'Starts the Astro website on http://localhost:4321/.'
    },
    {
      label: 'Open',
      command: 'http://localhost:4321/play-the-game',
      description: 'Loads the website showroom and embeds the running game app.'
    }
  ],
  notesTitle: 'Gameplay notes',
  notes: [
    'The menu, splashscreen, settings, credits, HUD, and fullscreen control come from the standalone game runtime.',
    'The Three.js/R3F scene is still loaded only when the play flow enters a gameplay screen.',
    'This iframe is a showroom and integration test, not a production distribution strategy yet.',
    'If the iframe is blank in development, check that npm run game:dev is running.'
  ],
  cta: 'Open standalone game',
  fallbackCta: 'Start game dev server'
};

const pagePath = '/play-the-game';
---

<Layout
  title={copy.seoTitle}
  description={copy.seoDescription}
  locale={locale}
  pagePath={pagePath}
  alternateLinks={buildLocalizedAlternates(pagePath)}
  localeSwitcherLinks={getLocaleSwitcherLinks(pagePath)}
  fullBleedMain
>
  <section class="play-showroom mx-auto flex w-full max-w-7xl flex-col gap-6">
    <div class="play-showroom__hero">
      <div class="max-w-3xl">
        <p class="play-showroom__eyebrow">{copy.eyebrow}</p>
        <h1>{copy.title}</h1>
        <p>{copy.lead}</p>
      </div>
      {gameEmbedUrl && (
        <a href={gameEmbedUrl} target="_blank" rel="noreferrer noopener" class="play-showroom__hero-link">
          {copy.cta}
        </a>
      )}
    </div>

    <div class="play-showroom__stage" aria-label={copy.launchLabel}>
      <div class="play-showroom__stage-header">
        <div>
          <p>{copy.launchLabel}</p>
          <h2>{copy.launchTitle}</h2>
        </div>
        <span>{hasGameEmbed ? gameEmbedUrl : 'PUBLIC_GAME_EMBED_URL missing'}</span>
      </div>

      <div class="play-showroom__screen">
        {hasGameEmbed ? (
          <iframe
            src={gameEmbedUrl}
            title="BboyArena standalone game"
            class="play-showroom__iframe"
            loading="lazy"
            allow="fullscreen; gamepad"
            allowfullscreen
            sandbox="allow-scripts allow-same-origin allow-pointer-lock allow-forms allow-popups"
          ></iframe>
        ) : (
          <div class="play-showroom__missing">
            <p>{copy.missingTitle}</p>
            <span>{copy.missingText}</span>
          </div>
        )}
      </div>
    </div>

    <div class="play-showroom__grid">
      <article class="play-showroom__panel play-showroom__panel--setup">
        <p class="play-showroom__eyebrow">{copy.setupTitle}</p>
        <h2>{copy.setupLead}</h2>
        <ol>
          {copy.steps.map((step) => (
            <li>
              <span>{step.label}</span>
              <code>{step.command}</code>
              <p>{step.description}</p>
            </li>
          ))}
        </ol>
      </article>

      <article class="play-showroom__panel">
        <p class="play-showroom__eyebrow">{copy.notesTitle}</p>
        <h2>What this page proves</h2>
        <ul>
          {copy.notes.map((note) => (
            <li>{note}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>
</Layout>

<style>
  .play-showroom {
    color: #2f281f;
  }

  .play-showroom__hero,
  .play-showroom__panel,
  .play-showroom__stage {
    border: 2px solid #4f4337;
    background:
      linear-gradient(180deg, rgba(248, 241, 231, 0.96), rgba(231, 218, 198, 0.94)),
      repeating-linear-gradient(0deg, rgba(95, 82, 69, 0.05) 0 1px, transparent 1px 6px);
    box-shadow: 0 10px 0 rgba(95, 82, 69, 0.35);
  }

  .play-showroom__hero {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    border-radius: 1.75rem;
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .play-showroom__eyebrow {
    margin: 0 0 0.75rem;
    color: #806a52;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.34em;
    text-transform: uppercase;
  }

  .play-showroom h1,
  .play-showroom h2 {
    margin: 0;
    color: #2a241d;
    font-weight: 950;
    letter-spacing: 0.12em;
    line-height: 0.96;
    text-transform: uppercase;
  }

  .play-showroom h1 {
    max-width: 52rem;
    font-size: clamp(2rem, 6vw, 5rem);
  }

  .play-showroom h2 {
    font-size: clamp(1.15rem, 2.4vw, 1.85rem);
  }

  .play-showroom p {
    margin: 1rem 0 0;
    max-width: 48rem;
    color: #574b3d;
    font-size: 1rem;
    line-height: 1.7;
  }

  .play-showroom__hero-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    border: 2px solid #2f281f;
    border-radius: 999px;
    background: linear-gradient(180deg, #f5d35a, #d59b13);
    box-shadow: 0 5px 0 #2f281f;
    color: #211a14;
    font-size: 0.72rem;
    font-weight: 950;
    letter-spacing: 0.24em;
    padding: 0.85rem 1.25rem;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      transform 160ms ease,
      box-shadow 160ms ease;
  }

  .play-showroom__hero-link:hover {
    box-shadow: 0 3px 0 #2f281f;
    transform: translateY(2px);
  }

  .play-showroom__stage {
    overflow: hidden;
    border-radius: 1.75rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(244, 190, 36, 0.16), transparent 34%),
      linear-gradient(180deg, #17130f, #070706 58%, #050505);
  }

  .play-showroom__stage-header {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 2px solid rgba(248, 241, 231, 0.16);
    padding: 1rem clamp(1rem, 2vw, 1.4rem);
    color: #f8f1e7;
  }

  .play-showroom__stage-header p {
    margin: 0 0 0.35rem;
    color: #f4be24;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.32em;
    line-height: 1;
    text-transform: uppercase;
  }

  .play-showroom__stage-header h2 {
    color: #f8f1e7;
    font-size: clamp(1rem, 2vw, 1.45rem);
  }

  .play-showroom__stage-header span {
    max-width: 100%;
    overflow: hidden;
    border: 1px solid rgba(248, 241, 231, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: #d8c8ad;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 0.45rem 0.65rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .play-showroom__screen {
    aspect-ratio: 16 / 9;
    min-height: 20rem;
    background:
      radial-gradient(circle at center, rgba(244, 190, 36, 0.1), transparent 30%),
      #050505;
  }

  .play-showroom__iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
    background: #050505;
  }

  .play-showroom__missing {
    display: grid;
    min-height: 20rem;
    place-items: center;
    padding: 2rem;
    text-align: center;
  }

  .play-showroom__missing p {
    margin: 0;
    color: #f8f1e7;
    font-size: clamp(1.25rem, 3vw, 2.25rem);
    font-weight: 950;
    letter-spacing: 0.16em;
    line-height: 1;
    text-transform: uppercase;
  }

  .play-showroom__missing span {
    display: block;
    max-width: 34rem;
    color: #d8c8ad;
    line-height: 1.7;
  }

  .play-showroom__grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .play-showroom__panel {
    border-radius: 1.5rem;
    padding: clamp(1.1rem, 2.5vw, 1.6rem);
  }

  .play-showroom__panel ol,
  .play-showroom__panel ul {
    display: grid;
    gap: 0.85rem;
    margin: 1.25rem 0 0;
    padding: 0;
  }

  .play-showroom__panel li {
    list-style: none;
    border: 1px solid rgba(79, 67, 55, 0.22);
    background: rgba(255, 255, 255, 0.34);
    color: #4f4337;
    line-height: 1.6;
    padding: 0.85rem;
  }

  .play-showroom__panel li span {
    display: block;
    color: #806a52;
    font-size: 0.62rem;
    font-weight: 950;
    letter-spacing: 0.26em;
    text-transform: uppercase;
  }

  .play-showroom__panel code {
    display: inline-block;
    margin-top: 0.45rem;
    border: 1px solid rgba(47, 40, 31, 0.24);
    background: #211a14;
    color: #f4be24;
    font-size: 0.82rem;
    font-weight: 850;
    padding: 0.35rem 0.5rem;
  }

  .play-showroom__panel li p {
    margin-top: 0.45rem;
    font-size: 0.92rem;
  }

  @media (max-width: 800px) {
    .play-showroom__grid {
      grid-template-columns: 1fr;
    }

    .play-showroom__screen {
      aspect-ratio: 9 / 14;
      min-height: 34rem;
    }
  }
</style>
