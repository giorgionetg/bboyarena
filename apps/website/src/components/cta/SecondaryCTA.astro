---
interface Props {
  label: string;
  title: string;
  description: string;
  cta: string;
  href?: string;
  icon: 'discord' | 'github' | 'instagram' | 'newsletter';
  external?: boolean;
  buttonPlacement?: 'inline' | 'bottom';
  buttonWidth?: 'auto' | 'full';
  minHeight?: 'compact' | 'default' | 'none';
  class?: string;
}

const {
  label,
  title,
  description,
  cta,
  href,
  icon,
  external = false,
  buttonPlacement = 'inline',
  buttonWidth = 'auto',
  minHeight = 'default',
  class: className = ''
} = Astro.props as Props;
const isBottom = buttonPlacement === 'bottom';
const buttonWidthClass = buttonWidth === 'full' ? 'w-full' : 'w-auto';
const minHeightClass = {
  compact: 'secondary-cta--compact',
  default: 'secondary-cta--default',
  none: 'secondary-cta--no-min-height'
}[minHeight];
---

<section class={`secondary-cta ${minHeightClass} rounded-[1.35rem] border-2 border-[#4f4337] bg-[rgba(247,240,229,0.96)] p-4 shadow-[0_10px_0_rgba(95,82,69,0.34)] sm:p-5 ${className}`}>
  <div class={`secondary-cta__layout ${isBottom ? 'secondary-cta__layout--bottom' : ''}`}>
    <div class="secondary-cta__icon flex h-11 w-11 shrink-0 items-center justify-center rounded-full border-2 border-[#4f4337] bg-[#8f8371] text-white shadow-[0_4px_0_rgba(95,82,69,0.22)]">
      {icon === 'discord' && (
        <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
          <path
            d="M7.4 7.2c1.1-.5 2.2-.8 3.5-.9l.1.2c-1.2.2-2.2.6-3 .9-.1 0-.2-.1-.3-.2Zm9.2 0c-.1.1-.2.2-.3.2-.8-.4-1.8-.7-3-.9l.1-.2c1.3.1 2.4.4 3.5.9ZM5.5 7.7c-1.1 1.4-1.8 3.3-1.8 5.4 0 1.6.4 3.1 1.1 4.4 1.5 1 3.2 1.7 5 2 .2-.4.4-.8.5-1.2-1-.1-1.8-.4-2.4-.8.5.1 1.1.2 1.7.3 1.1.1 2.2.1 3.2 0 1.1-.1 1.9-.2 2.4-.3-.6.4-1.4.7-2.4.8.1.4.3.8.5 1.2 1.8-.3 3.5-1 5-2 .7-1.3 1.1-2.8 1.1-4.4 0-2.1-.7-4-1.8-5.4-1.4-.6-2.8-1-4.2-1.2l-.5 1c-1-.1-1.9-.1-2.9 0l-.5-1c-1.4.2-2.8.6-4.2 1.2Zm4 5.8c0 .7-.5 1.3-1.2 1.3-.7 0-1.2-.6-1.2-1.3s.5-1.3 1.2-1.3c.7 0 1.2.6 1.2 1.3Zm6.4 0c0 .7-.5 1.3-1.2 1.3-.7 0-1.2-.6-1.2-1.3s.5-1.3 1.2-1.3c.7 0 1.2.6 1.2 1.3Z"
            fill="currentColor"
          />
        </svg>
      )}
      {icon === 'github' && (
        <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
          <path
            d="M12 2C6.5 2 2 6.5 2 12c0 4.4 2.9 8.1 6.8 9.4.5.1.7-.2.7-.5v-1.8c-2.8.6-3.4-1.2-3.4-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 0 1.5 1 1.5 1 1 .1 1.5.7 1.7 1 .4.8 1 1.1 1.4 1.2.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.1-4.7-5 0-1.1.4-2 1-2.7-.1-.3-.4-1.4.1-2.8 0 0 .8-.3 2.7 1a9.2 9.2 0 0 1 5 0c1.9-1.3 2.7-1 2.7-1 .5 1.4.2 2.5.1 2.8.6.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.7 5 .4.3.8.9.8 1.8v2.7c0 .3.2.6.7.5A10 10 0 0 0 22 12C22 6.5 17.5 2 12 2Z"
            fill="currentColor"
          />
        </svg>
      )}
      {icon === 'instagram' && (
        <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
          <path
            d="M7.5 4A3.5 3.5 0 0 0 4 7.5v9A3.5 3.5 0 0 0 7.5 20h9a3.5 3.5 0 0 0 3.5-3.5v-9A3.5 3.5 0 0 0 16.5 4h-9Zm0 1.5h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-9a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2Zm9.75 1.1a.9.9 0 1 0 0 1.8.9.9 0 0 0 0-1.8ZM12 7.1A4.9 4.9 0 1 0 16.9 12 4.91 4.91 0 0 0 12 7.1Zm0 1.5A3.4 3.4 0 1 1 8.6 12 3.4 3.4 0 0 1 12 8.6Z"
            fill="currentColor"
          />
        </svg>
      )}
      {icon === 'newsletter' && (
        <svg viewBox="0 0 24 24" class="h-7 w-7" aria-hidden="true">
          <path
            d="M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11A2.5 2.5 0 0 1 17.5 20h-11A2.5 2.5 0 0 1 4 17.5v-11Zm2.4-.7 5.6 4.2 5.6-4.2H6.4Zm11.2 12.2c.3 0 .6-.3.6-.6V8.7l-6 4.5a1 1 0 0 1-1.2 0l-6-4.5v8.7c0 .3.3.6.6.6h12Z"
            fill="currentColor"
          />
        </svg>
      )}
    </div>

    <div class="secondary-cta__body min-w-0 flex-1">
      <p class="text-[10px] font-black uppercase tracking-[0.32em] text-[#756553]">{label}</p>
      <div class={`secondary-cta__content mt-2 ${isBottom ? 'secondary-cta__content--bottom' : 'secondary-cta__content--inline'}`}>
        <div class="secondary-cta__copy min-w-0">
          <h2 class="text-lg font-black uppercase leading-[0.92] tracking-[0.12em] text-[#2d261f] sm:text-xl">
            {title}
          </h2>
          <p class="mt-2 max-w-xl text-sm leading-relaxed text-[#54483b]">
            {description}
          </p>
        </div>

        <div class="secondary-cta__action">
          {href ? (
            <a
              href={href}
              class={`street-button street-button-secondary ${buttonWidthClass} inline-flex min-h-11 shrink-0 items-center justify-center whitespace-nowrap rounded-[1.25rem] px-4 py-2 text-[10px] font-black uppercase tracking-[0.24em] transition hover:-translate-y-0.5`}
              target={external ? '_blank' : undefined}
              rel={external ? 'noreferrer noopener' : undefined}
            >
              {cta}
            </a>
          ) : (
            <span
              class={`street-button street-button-secondary ${buttonWidthClass} inline-flex min-h-11 shrink-0 items-center justify-center whitespace-nowrap rounded-[1.25rem] px-4 py-2 text-[10px] font-black uppercase tracking-[0.24em] opacity-50`}
              aria-disabled="true"
              title="Discord link not configured"
            >
              {cta}
            </span>
          )}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .secondary-cta {
    container-type: inline-size;
    container-name: secondary-cta;
    display: flex;
    height: 100%;
    overflow: hidden;
  }

  .secondary-cta--default {
    min-height: 20rem;
  }

  .secondary-cta--compact {
    min-height: 13rem;
  }

  .secondary-cta--no-min-height {
    min-height: 0;
  }

  .secondary-cta__layout {
    display: flex;
    align-items: center;
    flex: 1;
    gap: 1rem;
    min-width: 0;
  }

  .secondary-cta__layout--bottom {
    align-items: stretch;
  }

  .secondary-cta__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
  }

  .secondary-cta__content {
    display: flex;
    align-items: flex-start;
    flex: 1;
    gap: 1rem;
    min-height: 0;
  }

  .secondary-cta__content--bottom {
    flex-direction: column;
    align-items: stretch;
  }

  .secondary-cta__copy {
    flex: 1;
    min-height: 0;
  }

  .secondary-cta__action {
    display: flex;
    align-items: flex-end;
    margin-top: 1rem;
  }

  .secondary-cta__content--bottom .secondary-cta__action {
    margin-top: auto;
    padding-top: 1rem;
    width: 100%;
  }

  @container secondary-cta (max-width: 18rem) {
    .secondary-cta--default {
      min-height: 21.5rem;
    }

    .secondary-cta--compact {
      min-height: 15rem;
    }

    .secondary-cta__layout {
      flex-direction: column;
      align-items: stretch;
      gap: 0.9rem;
    }

    .secondary-cta__icon {
      align-self: center;
      width: 3rem;
      height: 3rem;
    }

    .secondary-cta__body {
      flex: 1;
      text-align: center;
    }

    .secondary-cta__content {
      flex-direction: column;
      flex: 1;
      align-items: stretch;
      gap: 0.9rem;
    }

    .secondary-cta__action {
      width: 100%;
    }

    .secondary-cta__action > * {
      width: 100%;
    }
  }
</style>
