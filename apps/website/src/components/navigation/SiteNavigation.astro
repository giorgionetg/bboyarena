---
import navData from '../../data/navigation.json';
import {
  buildLocalizedPath,
  getLocaleConfig,
  getLocaleSwitcherLinks,
  getSiteCopy,
  type LocaleCode
} from '../../lib/i18n';
import HomeLogo from './HomeLogo.astro';

interface Props {
  locale?: LocaleCode;
  pagePath?: string;
  localeSwitcherLinks?: { locale: LocaleCode; label: string; path: string }[];
  navLinks?: { label: string; path: string }[];
}

const {
  locale = 'en-US',
  pagePath = '/',
  localeSwitcherLinks: localeSwitcherLinksOverride,
  navLinks: navLinksOverride
} = Astro.props;
const copy = getSiteCopy(locale);
const currentLocale = getLocaleConfig(locale);
const currentLocaleShortLabel = currentLocale.path ? currentLocale.path.toUpperCase() : 'EN';
const navItems = navData.items as { key: keyof typeof copy.nav; path: string }[];
const navLinks = navLinksOverride ?? navItems.map((item) => ({ label: copy.nav[item.key], path: item.path }));
const localeSwitcherLinks = localeSwitcherLinksOverride ?? getLocaleSwitcherLinks(pagePath);
const normalizedPagePath = pagePath.replace(/\/+$/, '') || '/';
const isActiveNavPath = (path: string) => {
  const normalizedPath = path.replace(/\/+$/, '') || '/';
  if (normalizedPath === '/') return normalizedPagePath === '/';
  return normalizedPagePath === normalizedPath || normalizedPagePath.startsWith(`${normalizedPath}/`);
};
const isPrimaryNavPath = (path: string) => path.replace(/\/+$/, '') === '/founding-crew';
---

<div class="flex flex-col gap-4">
  <div class="flex items-center justify-between gap-3 sm:gap-4">
    <HomeLogo locale={locale} label="Breakdance 3D home" />

    <div class="hidden flex-1 items-center justify-end gap-3 sm:flex">
      <nav class="flex items-center gap-2 whitespace-nowrap text-xs font-black uppercase tracking-[0.24em]">
        {navLinks.map((item) => (
          <a
            href={buildLocalizedPath(locale, item.path)}
            class={`street-link-nav h-10 rounded-full px-3 transition ${isPrimaryNavPath(item.path) ? 'street-link-nav-primary px-4' : ''}`}
            aria-current={isActiveNavPath(item.path) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="relative" data-language-switcher>
        <button
          type="button"
          class="street-link-nav inline-flex h-10 items-center gap-2 rounded-full px-3 text-[10px] font-black uppercase tracking-[0.24em] transition"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-controls="language-switcher-panel"
          data-language-switcher-toggle
        >
          <span class="sr-only">{copy.switcher.label}</span>
          <span class="rounded-full border border-[#4f4337]/25 bg-[rgba(247,240,229,0.34)] px-2.5 py-1 text-[10px] leading-none tracking-[0.18em] text-[#4f4337]">
            {currentLocaleShortLabel}
          </span>
          <svg viewBox="0 0 24 24" class="h-4 w-4 text-[#2d251d]" aria-hidden="true">
            <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </button>

        <div
          id="language-switcher-panel"
          class="absolute right-0 top-[calc(100%+0.5rem)] z-20 hidden min-w-[14rem] rounded-[1.35rem] border-2 border-[#4f4337] bg-[rgba(247,240,229,0.98)] p-2 shadow-[0_10px_0_rgba(95,82,69,0.35)]"
          role="menu"
          data-language-switcher-panel
        >
          <div class="flex flex-col gap-2">
            {localeSwitcherLinks.map((link) => (
              <a
                href={link.path}
                class="street-link-nav inline-flex h-11 items-center justify-between rounded-[1rem] px-4 text-left text-[10px] font-black uppercase tracking-[0.24em] transition"
                aria-current={link.locale === locale ? 'page' : undefined}
                role="menuitem"
                data-language-switcher-item
              >
                <span>{link.label}</span>
                {link.locale === locale && <span class="text-[9px] tracking-[0.2em] text-[#5f5346]">Current</span>}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="flex items-center gap-2 sm:hidden">
      <button
        type="button"
        class="street-button inline-flex h-11 w-11 items-center justify-center rounded-full"
        aria-label="Open menu"
        aria-controls="mobile-menu-panel"
        aria-expanded="false"
        data-mobile-menu-open
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5 text-[#2d251d]" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu-panel"
    class="fixed inset-0 z-50 translate-y-[-110%] bg-[rgba(234,224,208,0.98)] opacity-0 pointer-events-none transition duration-300 ease-out sm:hidden"
    data-mobile-menu-panel
    aria-hidden="true"
  >
    <div class="flex h-[100dvh] flex-col gap-4 p-4">
      <div class="flex items-center justify-between gap-3">
        <HomeLogo locale={locale} label="Breakdance 3D home" />
        <button
          type="button"
          class="street-button inline-flex h-11 w-11 items-center justify-center rounded-full"
          aria-label="Close menu"
          aria-controls="mobile-menu-panel"
          aria-expanded="true"
          data-mobile-menu-close
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5 text-[#2d251d]" aria-hidden="true">
            <path d="M6 6l12 12M18 6L6 18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <div class="flex flex-1 flex-col gap-3 overflow-y-auto rounded-[1.5rem] border-2 border-[#4f4337] bg-[rgba(247,240,229,0.96)] p-3 shadow-[0_10px_0_rgba(95,82,69,0.35)]">
        <div class="flex flex-col gap-2">
          {navLinks.map((item) => (
            <a
              href={buildLocalizedPath(locale, item.path)}
              class={`street-link-nav rounded-[1rem] px-4 py-3 text-left text-sm font-black uppercase tracking-[0.24em] transition ${isPrimaryNavPath(item.path) ? 'street-link-nav-primary justify-center' : ''}`}
              aria-current={isActiveNavPath(item.path) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </div>
        <div class="mt-auto flex flex-col gap-3 border-t-2 border-[#4f4337]/30 pt-3">
          <div class="flex items-center justify-between gap-3">
            <p class="text-[10px] font-black uppercase tracking-[0.24em] text-[#5f5346]">{copy.switcher.label}</p>
            <button
              type="button"
              class="street-link-nav inline-flex h-10 items-center gap-2 rounded-full px-3 text-[10px] font-black uppercase tracking-[0.24em] transition"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-controls="mobile-language-switcher-panel"
              data-mobile-language-switcher-toggle
            >
              <span class="rounded-full border border-[#4f4337]/25 bg-[rgba(247,240,229,0.34)] px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.18em] text-[#4f4337]">
                {currentLocaleShortLabel}
              </span>
              <svg viewBox="0 0 24 24" class="h-4 w-4 text-[#2d251d]" aria-hidden="true">
                <path d="M6 9l6 6 6-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </div>

          <div
            id="mobile-language-switcher-panel"
            class="hidden flex-col gap-2"
            role="menu"
            data-mobile-language-switcher-panel
          >
            {localeSwitcherLinks
              .filter((link) => link.locale !== locale)
              .map((link) => (
                <a
                  href={link.path}
                  class="street-link-nav flex h-11 w-full items-center justify-between rounded-[1rem] px-4 text-left text-[10px] font-black uppercase tracking-[0.24em] transition"
                  role="menuitem"
                >
                  <span>{link.label}</span>
                </a>
              ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const openButton = document.querySelector('[data-mobile-menu-open]');
    const closeButton = document.querySelector('[data-mobile-menu-close]');
    const panel = document.querySelector('[data-mobile-menu-panel]');
    const languageToggle = document.querySelector('[data-language-switcher-toggle]');
    const languagePanel = document.querySelector('[data-language-switcher-panel]');
    const mobileLanguageToggle = document.querySelector('[data-mobile-language-switcher-toggle]');
    const mobileLanguagePanel = document.querySelector('[data-mobile-language-switcher-panel]');

    if (openButton && closeButton && panel) {
      const showPanel = () => {
        panel.classList.remove('translate-y-[-110%]', 'opacity-0', 'pointer-events-none');
        panel.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
        panel.setAttribute('aria-hidden', 'false');
        openButton.setAttribute('aria-expanded', 'true');
      };

      const hidePanel = () => {
        panel.classList.add('translate-y-[-110%]', 'opacity-0', 'pointer-events-none');
        panel.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
        panel.setAttribute('aria-hidden', 'true');
        openButton.setAttribute('aria-expanded', 'false');
      };

      openButton.addEventListener('click', () => {
        const isClosed = panel.classList.contains('translate-y-[-110%]');
        if (isClosed) {
          showPanel();
        } else {
          hidePanel();
        }
      });

      closeButton.addEventListener('click', hidePanel);

      panel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          hidePanel();
        });
      });
    }

    if (languageToggle && languagePanel) {
      const showLanguagePanel = () => {
        languagePanel.classList.remove('hidden');
        languageToggle.setAttribute('aria-expanded', 'true');
      };

      const hideLanguagePanel = () => {
        languagePanel.classList.add('hidden');
        languageToggle.setAttribute('aria-expanded', 'false');
      };

      languageToggle.addEventListener('click', () => {
        const isHidden = languagePanel.classList.contains('hidden');
        if (isHidden) {
          showLanguagePanel();
        } else {
          hideLanguagePanel();
        }
      });

      languagePanel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          hideLanguagePanel();
        });
      });
    }

    if (mobileLanguageToggle && mobileLanguagePanel) {
      const showMobileLanguagePanel = () => {
        mobileLanguagePanel.classList.remove('hidden');
        mobileLanguageToggle.setAttribute('aria-expanded', 'true');
      };

      const hideMobileLanguagePanel = () => {
        mobileLanguagePanel.classList.add('hidden');
        mobileLanguageToggle.setAttribute('aria-expanded', 'false');
      };

      mobileLanguageToggle.addEventListener('click', () => {
        const isHidden = mobileLanguagePanel.classList.contains('hidden');
        if (isHidden) {
          showMobileLanguagePanel();
        } else {
          hideMobileLanguagePanel();
        }
      });

      mobileLanguagePanel.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          hideMobileLanguagePanel();
        });
      });
    }
  </script>
</div>
