---
import Layout from '../../../components/layout/Layout.astro';
import {
  buildLocalizedAlternates,
  buildLocalizedPath,
  getLocaleCodeFromPath,
  getSiteCopy,
  SUPPORTED_LOCALES
} from '../../../lib/i18n';

export async function getStaticPaths() {
  return SUPPORTED_LOCALES.filter((locale) => locale !== 'en-US').map((locale) => ({
    params: { locale: locale === 'pt-BR' ? 'pt-br' : locale === 'zh-Hans' ? 'zh' : locale === 'it-IT' ? 'it' : 'es' }
  }));
}

const locale = getLocaleCodeFromPath(Astro.params.locale);
const copy = getSiteCopy(locale);
const devlogHref = buildLocalizedPath(locale, '/news/devlog');
---

<Layout
  title={`BboyArena - ${copy.news.devlogArchive}`}
  description={copy.news.categories.devlog.description}
  locale={locale}
  pagePath="/news"
  canonical={devlogHref}
  alternateLinks={buildLocalizedAlternates('/news/devlog')}
  noindex
>
  <script is:inline define:vars={{ devlogHref }}>
    {`window.location.replace(devlogHref);`}
  </script>

  <section class="mx-auto w-full max-w-4xl street-panel rounded-[1.75rem] p-5 sm:p-7">
    <p class="text-[10px] font-black uppercase tracking-[0.38em] text-[#756553]">{copy.news.eyebrow}</p>
    <h1 class="mt-3 text-4xl font-black uppercase leading-[0.92] tracking-[0.16em] text-[#2d261f] sm:text-5xl">
      {copy.news.devlogArchive}
    </h1>
    <p class="mt-4 max-w-2xl text-sm leading-relaxed text-[#54483b] sm:text-base">
      Redirecting to the public devlog archive. If nothing happens, open the devlog from the button below.
    </p>
    <div class="mt-6">
      <a
        href={devlogHref}
        class="street-button street-button-primary inline-flex rounded-[1.25rem] px-6 py-3 text-xs font-black uppercase tracking-[0.28em] transition hover:-translate-y-0.5"
      >
        {copy.news.devlogArchive}
      </a>
    </div>
  </section>
</Layout>
