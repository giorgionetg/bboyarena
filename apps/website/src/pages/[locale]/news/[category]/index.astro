---
import Layout from '../../../../components/layout/Layout.astro';
import {
  NEWS_CATEGORIES,
  getNewsCategoryPath,
  getNewsItemsByCategory,
  isExternalNewsItem,
  type NewsCategory
} from '../../../../lib/news';
import PanoramaFallback from '../../../../components/media/PanoramaFallback.astro';
import {
  buildLocalizedAlternates,
  buildLocalizedPath,
  getLocaleCodeFromPath,
  getSiteCopy,
  SUPPORTED_LOCALES
} from '../../../../lib/i18n';
import { buildPocketBaseDevlogListUrl } from '../../../../lib/pocketbase';

export async function getStaticPaths() {
  const paths: { params: { locale: string; category: string } }[] = [];
  const localePaths = SUPPORTED_LOCALES.filter((locale) => locale !== 'en-US').map((locale) =>
    locale === 'pt-BR' ? 'pt-br' : locale === 'zh-Hans' ? 'zh' : locale === 'it-IT' ? 'it' : 'es'
  );

  for (const locale of localePaths) {
    for (const category of Object.keys(NEWS_CATEGORIES)) {
      paths.push({ params: { locale, category } });
    }
  }

  return paths;
}

const locale = getLocaleCodeFromPath(Astro.params.locale);
const copy = getSiteCopy(locale);
const categoryParam = Astro.params.category ?? '';
const categoryKey = categoryParam as NewsCategory;
const category = NEWS_CATEGORIES[categoryKey];
const items = await getNewsItemsByCategory(categoryKey);
const pocketBaseDevlogListUrl = categoryKey === 'devlog' ? buildPocketBaseDevlogListUrl(8) : null;
const devlogBasePath = buildLocalizedPath(locale, '/news/devlog');
const isDevlogArchive = categoryKey === 'devlog';
const devlogPanoramaCopy =
  locale === 'it-IT'
    ? {
        title: 'Uno sguardo allo stato del gioco',
        description:
          'Al momento questo spazio e una vista panorama esplorabile. In futuro potra diventare un pannello Three.js live con scena giocabile, stato del prototipo e avanzamento visivo.'
      }
    : {
        title: 'A look at the game state',
        description:
          'Right now this space is an explorable panorama. Later it can become a live Three.js panel with the current playable scene, prototype status, and visual progress.'
      };
---

<Layout
  title={`${copy.news.categories[categoryKey].title} - Breakdance 3D`}
  description={copy.news.categories[categoryKey].description}
  locale={locale}
  pagePath={`/news/${categoryKey}`}
  canonical={buildLocalizedPath(locale, getNewsCategoryPath(categoryKey))}
  alternateLinks={buildLocalizedAlternates(`/news/${categoryKey}`)}
  type="website"
>
  <div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
    <section class="street-panel rounded-[1.75rem] p-5 sm:p-7">
      <p class="text-[10px] font-black uppercase tracking-[0.38em] text-[#756553]">{copy.news.categories[categoryKey].label}</p>
      <h1 class="mt-3 text-4xl font-black uppercase leading-[0.92] tracking-[0.16em] text-[#2d261f] sm:text-6xl">
        {copy.news.categories[categoryKey].title}
      </h1>
      <p class="mt-4 max-w-3xl text-sm leading-relaxed text-[#54483b] sm:text-base">{copy.news.categories[categoryKey].description}</p>
    </section>

    <section class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="street-panel rounded-[1.75rem] p-5 sm:p-7">
        <div class="flex items-center justify-between gap-3">
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-[#756553]">Archive</p>
          <a href={devlogBasePath} class="text-[10px] font-black uppercase tracking-[0.26em] text-[#7c8f4c]">
            Devlog home
          </a>
        </div>

        <div class="mt-6 grid gap-4" data-pb-devlog-archive>
          {items.length > 0 ? (
            items.map((item) => (
              <article class="rounded-[1.25rem] border-2 border-[#4f4337] bg-[#f6efe4] p-4 shadow-[0_8px_0_rgba(95,82,69,0.25)]">
                <div class="flex flex-wrap items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em]">
                  <span class="street-chip rounded-full px-2.5 py-1" style={`background:${category.accent}22;color:${category.accent}`}>
                    {copy.news.categories[categoryKey].label}
                  </span>
                  <span class="text-[#756553]">{new Date(item.publishedTime).toLocaleDateString('en-US')}</span>
                  {isExternalNewsItem(item) && <span class="text-[#bc613a]">{item.sourceName}</span>}
                </div>
                <h2 class="mt-3 text-xl font-black uppercase tracking-[0.12em] text-[#2d261f]">{item.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-[#54483b]">{item.excerpt}</p>
                <div class="mt-4 flex flex-wrap items-center gap-3 text-[10px] font-black uppercase tracking-[0.24em]">
                  <a
                    href={buildLocalizedPath(locale, `/news/${item.category}/${item.slug}`)}
                    class="street-button rounded-full px-3 py-1.5 text-[#2d251d] transition hover:bg-[#f4ebdf]"
                  >
                    Open
                  </a>
                  {isExternalNewsItem(item) && (
                    <a href={item.sourceUrl} target="_blank" rel="noreferrer" class="text-[#bc613a] transition hover:text-[#9d4d2d]">
                      Source
                    </a>
                  )}
                </div>
              </article>
            ))
          ) : (
            <PanoramaFallback
              image="/equirectangular-01.png"
            />
          )}
        </div>
      </div>

      {isDevlogArchive ? (
        <aside class="street-dark flex min-h-[28rem] overflow-hidden rounded-[1.75rem] p-0">
          <PanoramaFallback
            image="/equirectangular-01.png"
            fillParent
            overlayTitle={devlogPanoramaCopy.title}
            overlayDescription={devlogPanoramaCopy.description}
          />
        </aside>
      ) : (
        <aside class="street-dark rounded-[1.75rem] p-5 sm:p-7">
          <p class="text-[10px] font-black uppercase tracking-[0.38em] text-[#d9c9b1]">{copy.news.categoryRules}</p>
          <div class="mt-4 space-y-4 text-sm leading-relaxed text-[#f8f1e7]">
            {copy.news.rules[categoryKey].map((paragraph) => (
              <p>{paragraph}</p>
            ))}
          </div>
        </aside>
      )}
    </section>
  </div>

  {pocketBaseDevlogListUrl && (
    <script define:vars={{ pocketBaseDevlogListUrl, devlogBasePath, locale }}>
      {`
        (() => {
          const archive = document.querySelector('[data-pb-devlog-archive]');
          if (!archive) return;

          const escapeHtml = (value) =>
            String(value ?? '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
              .replace(/'/g, '&#39;');

          const renderCard = (item) => {
            const slug = String(item.slug || item.id || '').trim();
            const title = escapeHtml(item.title || 'Untitled devlog');
            const excerpt = escapeHtml(item.excerpt || item.description || '');
            const publishedTime = item.publishedTime || item.created || '';
            const author = escapeHtml(item.author || 'PocketBase');

            return \`
              <article class="rounded-[1.25rem] border-2 border-[#4f4337] bg-[#f6efe4] p-4 shadow-[0_8px_0_rgba(95,82,69,0.25)]">
                <div class="flex flex-wrap items-center gap-2 text-[10px] font-black uppercase tracking-[0.24em]">
                  <span class="street-chip rounded-full px-2.5 py-1" style="background:#7c8f4c22;color:#7c8f4c">Devlog</span>
                  <span class="text-[#756553]">${publishedTime ? new Date(publishedTime).toLocaleDateString(locale) : ''}</span>
                  <span class="text-[#bc613a]">${author}</span>
                </div>
                <h2 class="mt-3 text-xl font-black uppercase tracking-[0.12em] text-[#2d261f]">${title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-[#54483b]">${excerpt}</p>
                ${slug ? \`
                  <div class="mt-4 flex flex-wrap items-center gap-3 text-[10px] font-black uppercase tracking-[0.24em]">
                    <a href="${devlogBasePath}/${slug}" class="street-button rounded-full px-3 py-1.5 text-[#2d251d] transition hover:bg-[#f4ebdf]">
                      ${copy.news.readMore}
                    </a>
                  </div>
                \` : ''}
              </article>
            \`;
          };

          const loadPocketBaseDevlogs = async () => {
            try {
              const response = await fetch(pocketBaseDevlogListUrl, { headers: { Accept: 'application/json' } });
              if (!response.ok) return;

              const payload = await response.json();
              const records = Array.isArray(payload?.items) ? payload.items : [];
              if (records.length === 0) return;

              archive.innerHTML = records.slice(0, 8).map(renderCard).join('');
            } catch {
              // Keep the static fallback.
            }
          };

          void loadPocketBaseDevlogs();
        })();
      `}
    </script>
  )}
</Layout>
